---
import Watermark from "./watermark.astro";
import type { Category } from "../data/resume";

interface Props {
  id: string;
  title: string;
  date: string;
  role: string;
  color: string;
  category: Category;
  description: string;
  problem?: string;
  solution?: string;
  impact?: string;
  tags?: readonly string[];
  liveUrl?: string;
  repoUrl?: string;
  caseStudyHref?: string;
  media?: { type: "video" | "image"; url: string; thumbnail?: string };
}

const {
  id,
  title,
  date,
  role,
  color,
  category,
  description,
  problem,
  solution,
  impact,
  tags = [],
  liveUrl,
  repoUrl,
  caseStudyHref,
  media,
} = Astro.props;

const cardImage =
  media?.type === "video" && media.thumbnail ? media.thumbnail : media?.url;
const fallBackImage = `https://picsum.photos/seed/${id}/800/600`;
---

<article
  class="panel radius-card overflow-hidden flex flex-col transition-all duration-300 hover:-translate-y-1 hover:border-[color:var(--card-accent)] hover:shadow-[0_20px_50px_-20px_var(--card-accent)]"
  data-project-id={id}
  style={`--card-accent: ${category === "marketing" ? "var(--mkt)" : "var(--sw)"}`}
>
  <div
    class="aspect-video w-full relative overflow-hidden"
    style={`background-color: ${color}18`}
  >
    {
      media?.type === "video" && (
        <div class="absolute inset-0 flex items-center justify-center bg-black/40 z-10">
            <div
              class="w-12 h-12 flex items-center justify-center rounded-full text-white shadow-xl"
              style={`background-color: var(--card-accent)`}
            >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </div>
      )
    }
    {
      cardImage ? (
        <div class="protected-image relative w-full h-full">
          <img
            src={cardImage}
            alt={title}
            class="w-full h-full object-cover opacity-90"
            loading="lazy"
          />
          <Watermark />
        </div>
      ) : (
        <img
          src={fallBackImage}
          alt={title}
          class="w-full h-full object-cover opacity-70"
          loading="lazy"
        />
      )
    }
    <div
      class="absolute top-3 left-3 z-20 panel rounded-md px-2 py-1 text-[10px] font-mono font-bold uppercase tracking-widest muted"
    >
      {date}
    </div>
  </div>

  <div class="p-5 md:p-6 flex flex-col flex-1">
    <div class="mb-3">
      <h3
        class="font-grotesk text-lg md:text-xl font-extrabold text-[color:var(--text)] tracking-tight leading-snug"
      >
        {title}
      </h3>
        <p
          class="text-[color:var(--card-accent)] text-[11px] font-bold uppercase tracking-widest mt-1"
        >
        {role}
      </p>
    </div>

    <p class="muted text-sm leading-relaxed mb-5">{description}</p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 mb-5">
      {
        problem && (
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest faint mb-1">
              Problem
            </p>
            <p class="text-[12px] muted leading-snug">{problem}</p>
          </div>
        )
      }
      {
        solution && (
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest faint mb-1">
              Solution
            </p>
            <p class="text-[12px] muted leading-snug">{solution}</p>
          </div>
        )
      }
      {
        impact && (
          <div>
            <p class="text-[10px] font-bold uppercase tracking-widest faint mb-1">
              Impact
            </p>
            <p class="text-[12px] text-[color:var(--text)] leading-snug font-medium">
              {impact}
            </p>
          </div>
        )
      }
    </div>

    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-5">
          {tags.map((t) => (
            <span class="px-2 py-0.5 panel radius-btn text-[10px] font-mono muted">
              {t}
            </span>
          ))}
        </div>
      )
    }

    <div class="mt-auto flex flex-wrap items-center gap-2 pt-2 border-t hairline">
      {
        liveUrl && liveUrl.length > 0 && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="track-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider transition-all"
          >
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            Live demo
          </a>
        )
      }
      {
        repoUrl && repoUrl.length > 0 && (
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="panel inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider text-[color:var(--text-muted)] hover:text-[color:var(--text)] hover:border-[color:var(--border-strong)] transition-all"
          >
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
            </svg>
            GitHub
          </a>
        )
      }
      {
        caseStudyHref && (
          <a
            href={caseStudyHref}
            class="ml-auto inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider text-[color:var(--text-muted)] hover:text-[color:var(--card-accent)] transition-colors"
          >
            Case study
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        )
      }
    </div>
  </div>
</article>
