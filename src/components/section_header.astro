---
interface Props {
  title: string;
  subtitle?: string;
  id?: string;
}
const { title, subtitle, id } = Astro.props;
---

<div class="mb-8 md:mb-10" id={id}>
  <h2 class="text-sm font-bold uppercase tracking-[0.2em] text-[color:var(--text)]">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-2 muted text-sm leading-relaxed max-w-2xl">{subtitle}</p>
  )}
</div>
