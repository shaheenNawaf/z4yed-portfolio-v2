---
interface Props {
  id: string;
  title: string;
  date: string;
  role: string;
  color: string;
  description: string;
  tags?: readonly string[];
  liveUrl?: string;
  repoUrl?: string;
  media?: {
    type: "video" | "image";
    url: string;
  };
}
const {
  id,
  title,
  date,
  role,
  color,
  tags = [],
  description,
  media,
  liveUrl,
  repoUrl,
} = Astro.props;
---

<div
  class="group bg-zinc-950/40 backdrop-blur-md border border-white/5 rounded-2xl overflow-hidden cursor-pointer transition-all duration-300 hover:border-zinc-700 hover:shadow-[0_0_30px_-10px_rgba(59,130,246,0.3)] hover:-translate-y-1"
  data-modal-id={id}
>
  <div class="h-40 w-full" style={`background-color: ${color}`}>
    {
      media && media.type === "image" && (
        <img
          src={media.url}
          alt={title}
          class="w-full h-full object-cover opacity-50 group-hover:opacity-100 transition-opacity"
        />
      )
    }
  </div>
  <div class="p-4">
    <h3
      class="text-sm font-medium text-white group-hover:text-blue-400 transition-colors"
    >
      {title}
    </h3>
    <div class="flex gap-3 text-xs text-zinc-500 mt-1">
      <span>📅 {date}</span>
      <span>👤 {role}</span>
    </div>
  </div>
</div>

<dialog
  id={id}
  class="fixed inset-0 m-auto bg-zinc-950/60 backdrop-blur-xl border border-blue-500/10 rounded-3xl max-w-3xl w-[95%] focus:outline-none overflow-hidden shadow-[0_0_50px_-12px_rgba(59,130,246,0.3)]"
>
  <div class="flex flex-col relative">
    <button
      class="absolute top-4 right-4 text-zinc-400 hover:text-white close-modal z-20 bg-black/50 w-8 h-8 rounded-full flex items-center justify-center transition-colors"
      >✕</button
    >

    <div
      class="w-full bg-zinc-800 overflow-hidden aspect-video relative flex items-center justify-center"
    >
      {
        media ? (
          media.type === "video" ? (
            <iframe
              src={media.url}
              class="w-full h-full aspect-video"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            />
          ) : (
            <img
              src={media.url}
              alt={title}
              class="w-full h-full object-cover"
            />
          )
        ) : (
          <div class="w-full h-full" style={`background-color: ${color}`} />
        )
      }
    </div>

    <div class="p-8">
      <h2 class="text-2xl font-bold text-white mb-2">{title}</h2>
      <div class="flex flex-wrap gap-2 mb-6">
        {
          tags.map((tag) => (
            <span class="px-2 py-1 bg-zinc-800 border border-zinc-700 rounded text-[10px] uppercase tracking-wider text-zinc-400 font-bold">
              {tag}
            </span>
          ))
        }
      </div>

      <p class="text-sm leading-relaxed text-zinc-400 mb-8">
        {description}
      </p>

      {
        (liveUrl || repoUrl) && (
          <div class="flex gap-4">
            {liveUrl && (
              <a
                href={liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="px-6 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg text-sm font-medium transition-all hover:shadow-[0_0_15px_rgba(37,99,235,0.4)]"
              >
                Visit Live Site
              </a>
            )}
            {repoUrl && (
              <a
                href={repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="px-6 py-2 bg-zinc-800 hover:bg-zinc-700 text-white rounded-lg text-sm font-medium transition-colors"
              >
                View Code
              </a>
            )}
          </div>
        )
      }
    </div>
  </div>
</dialog>
