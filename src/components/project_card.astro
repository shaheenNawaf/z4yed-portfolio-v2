---
import type { Category } from "../data/resume";

interface Props {
  id: string;
  title: string;
  date: string;
  role: string;
  color: string;
  category: Category;
  description: string;
  results?: string;
  deliverables?: string[];
  gallery?: string[];
  tags?: readonly string[];
  media?: { type: "video" | "image"; url: string; thumbnail?: string };
  liveUrl?: string;
  repoUrl?: string;
  problem?: string;
  solution?: string;
  impact?: string;
  caseStudyHref?: string;
}

const {
  id,
  title,
  date,
  role,
  color,
  category,
  description,
  results,
  deliverables = [],
  gallery = [],
  tags = [],
  media,
  liveUrl,
  repoUrl,
  problem,
  solution,
  impact,
  caseStudyHref,
} = Astro.props;

const cardImage =
  media?.type === "video" && media.thumbnail ? media.thumbnail : media?.url;
const fallBackImage = `https://picsum.photos/seed/${id}/800/600`;
const metric = results ?? impact;
const listItems = category === "software" || category === "systems" ? tags : deliverables;
const listHeading = category === "software" || category === "systems" ? "Stack" : "Deliverables";

const accentVar =
  category === "marketing" ? "var(--mkt)" : category === "software" ? "var(--sw)" : "var(--accent)";
---

<article
  class="project-card surface radius-card overflow-hidden flex flex-col transition-all duration-200 cursor-pointer group hover:border-[color:var(--card-accent)]"
  data-project-card={id}
  data-category={category}
  style={`--card-accent: ${accentVar}`}
  tabindex="0"
  role="button"
  aria-label={`View case study: ${title}`}
>
  <div
    class="aspect-video w-full relative overflow-hidden max-h-[180px] md:max-h-none"
    style={`background-color: ${color}18`}
  >
    {
      media?.type === "video" && (
        <div class="absolute inset-0 flex items-center justify-center bg-black/40 group-hover:bg-black/20 transition-colors z-10">
          <div
            class="w-12 h-12 flex items-center justify-center rounded-full shadow-xl group-hover:scale-110 transition-transform text-white"
            style={`background-color: ${accentVar}`}
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </div>
      )
    }
    {
      cardImage ? (
        <div class="relative w-full h-full overflow-hidden protected-image select-none">
          <img
            src={cardImage}
            alt={title}
            class="w-full h-full object-cover group-hover:scale-[1.02] transition-all duration-500"
            loading="lazy"
          />
        </div>
      ) : (
        <div class="absolute inset-0">
          <img
            src={fallBackImage}
            alt={title}
            class="w-full h-full object-cover opacity-50 group-hover:opacity-80 transition-opacity duration-500"
            loading="lazy"
          />
          <div
            class="absolute inset-0 opacity-20"
            style="background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 20px 20px;"
          />
        </div>
      )
    }
  </div>

  <div class="p-4 md:p-8 flex flex-col flex-1">
    {
      metric && (
        <div
          class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-bold mb-4 self-start"
          style={`background-color: ${accentVar}18; color: ${accentVar}`}
        >
          {metric}
        </div>
      )
    }

    <h3
      class="text-lg md:text-xl font-bold text-[color:var(--text)] tracking-tight leading-snug mb-1 group-hover:text-[color:var(--card-accent)] transition-colors"
    >
      {title}
    </h3>
    <p
      class="text-[color:var(--card-accent)] text-xs font-medium mb-3"
    >
      {role}
    </p>

    <p class="muted text-sm leading-relaxed mb-4 line-clamp-2">{description}</p>

    {
      listItems.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mb-3 md:mb-4">
          {listItems.slice(0, 8).map((item: string, index: number) => (
            <span class:list={["px-2 py-0.5 panel radius-btn text-[10px] font-mono muted", { "hidden md:inline-flex": index >= 3 }]}>
              {item}
            </span>
          ))}
        </div>
      )
    }

    <div class="mt-auto flex flex-wrap items-center gap-2 pt-3">
      {
        liveUrl && liveUrl.length > 0 && (
          <a
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="panel inline-flex items-center justify-center w-8 h-8 rounded-lg text-[color:var(--text-muted)] hover:text-[color:var(--text)] hover:border-[color:var(--border-strong)] transition-all"
            title="Live demo"
            onclick="event.stopPropagation()"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )
      }
      {
        repoUrl && repoUrl.length > 0 && (
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="panel inline-flex items-center justify-center w-8 h-8 rounded-lg text-[color:var(--text-muted)] hover:text-[color:var(--text)] hover:border-[color:var(--border-strong)] transition-all"
            title="GitHub"
            onclick="event.stopPropagation()"
          >
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
        )
      }
      <span class="ml-auto inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[11px] font-bold uppercase tracking-wider text-[color:var(--text-muted)] group-hover:text-[color:var(--card-accent)] transition-colors">
        View Case Study
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    </div>
  </div>
</article>
