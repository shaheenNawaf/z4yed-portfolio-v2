---
import { hubStats } from "../data/resume";
import { FeaturedCard } from "./react/FeaturedCard";
import { DitherSparkline } from "./react/DitherSparkline";
import { FeaturedGrowthViz } from "./react/FeaturedGrowthViz";

const featured = hubStats[0];
const supporting = hubStats.slice(1);

const sparklineData = [
  { values: [2, 5, 10, 16, 22], color: "orange" as const },
  { values: [1, 4, 8, 15, 25], color: "orange" as const },
  { values: [1, 2, 2.5, 3.5, 4], color: "orange" as const },
  { values: [0, 1, 1, 2, 2], color: "blue" as const },
];

// Growth journey: $6K/mo → $355K total in 4 months
const growthJourney = [
  { month: "Mar", value: "$6K", rawValue: 6 },
  { month: "Jun", value: "$45K", rawValue: 45, joined: true },
  { month: "Aug", value: "$155K", rawValue: 155 },
  { month: "Sep", value: "$355K", rawValue: 355 },
];

const counterTargets = [100, 68, 52, 40, 20];
---

<section id="proof" class="relative py-16 md:py-32">
  <div class="max-w-6xl mx-auto px-5 md:px-8">
    <div class="mb-10 md:mb-14">
      <h2
        class="text-3xl md:text-4xl font-bold text-[color:var(--text)] tracking-tight"
      >
        Proof, not promises
      </h2>
      <p class="mt-3 text-base md:text-lg muted max-w-2xl">
        Real outcomes from live products and campaigns.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 md:gap-5">
      {/* Mobile stats block */}
      <div class="md:hidden">
        {/* Hero stat */}
        <div class="text-center mb-6">
          <p
            class="stat-number text-5xl md:text-6xl font-bold text-[color:var(--text)] tracking-tighter leading-none"
            data-value={featured.value}
          >
            {featured.value}
          </p>
        </div>

        {/* Supporting stats grid */}
        <div class="panel radius-card overflow-hidden">
          <div class="grid grid-cols-2">
            {
              supporting.map((stat, i) => (
                <div
                  class:list={[
                    "flex flex-col items-center justify-center text-center py-5 px-4",
                    {
                      "border-r border-b border-[color:color-mix(in_srgb,var(--border)_20%,transparent)]":
                        i === 0,
                      "border-b border-[color:color-mix(in_srgb,var(--border)_20%,transparent)]":
                        i === 1,
                      "border-r border-[color:color-mix(in_srgb,var(--border)_20%,transparent)]":
                        i === 2,
                    },
                  ]}
                >
                  <p
                    class="stat-number text-4xl font-bold text-[color:var(--text)] tracking-tighter"
                    data-value={stat.value}
                  >
                    {stat.value}
                  </p>
                  <p class="mt-2 text-xs font-medium text-[color:var(--text)] leading-snug">
                    {stat.label}
                  </p>
                  <p class="mt-1 text-[11px] muted leading-snug">{stat.sub}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      {/* Featured stat */}
      <div
        class="hidden md:block lg:col-span-5 panel radius-card p-5 md:p-6 reveal-section group/card transition-all duration-200 hover:-translate-y-0.5"
        style={`background: radial-gradient(ellipse 60% 60% at 95% 5%, ${featured.accent === "marketing" ? "rgba(249,115,22,0.06)" : "rgba(59,130,246,0.06)"} 0%, transparent 60%), var(--panel-bg);`}
      >
        {/* Hover glow border */}
        <div
          class="absolute inset-0 pointer-events-none rounded-[inherit] opacity-0 group-hover/card:opacity-100 transition-opacity duration-200"
          style={`box-shadow: inset 0 0 0 1px ${featured.accent === "marketing" ? "rgba(249,115,22,0.2)" : "rgba(59,130,246,0.2)"};`}
        >
        </div>
        <FeaturedCard
          client:load
          accentColor={featured.accent as "marketing" | "software"}
        >
          <div class="flex flex-col h-full">
            {/* Header */}
            <div class="flex items-center gap-2 mb-4">
              <p
                class="text-[13px] font-medium uppercase tracking-widest"
                style={`color: ${featured.accent === "marketing" ? "var(--mkt)" : "var(--sw)"}`}
              >
                {featured.label}
              </p>
              <svg
                class="w-3 h-3 opacity-70"
                viewBox="0 0 12 12"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M2 8 L6 4 L10 8"
                  stroke={featured.accent === "marketing"
                    ? "var(--mkt)"
                    : "var(--sw)"}
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </div>

            {/* Big number */}
            <p
              class="stat-number text-5xl md:text-6xl font-bold text-[color:var(--text)] tracking-tighter leading-none"
              data-value={featured.value}
            >
              {featured.value}
            </p>

            {/* Growth journey */}
            <div class="mt-6 pt-5 border-t border-[rgba(255,255,255,0.06)]">
              <FeaturedGrowthViz
                client:load
                data={growthJourney}
                color={featured.accent === "marketing" ? "orange" : "blue"}
              />
            </div>

            {/* Subtext */}
            <p class="mt-5 text-[13px] muted leading-relaxed">
              {featured.sub}
            </p>
          </div>
        </FeaturedCard>
      </div>

      {/* Supporting stats */}
      <div class="hidden md:grid lg:col-span-7 grid-cols-2 gap-4 md:gap-5">
        {
          supporting.map((stat, i) => (
            <div
              class="panel radius-card p-5 md:p-6 reveal-section flex flex-col justify-between relative overflow-hidden group/stat transition-all duration-200 hover:-translate-y-0.5"
              style={`transition-delay: ${(i + 1) * 90}ms;`}
            >
              {/* Hover glow border */}
              <div
                class="absolute inset-0 pointer-events-none rounded-[inherit] opacity-0 group-hover/stat:opacity-100 transition-opacity duration-200"
                style={`box-shadow: inset 0 0 0 1px ${stat.accent === "marketing" ? "rgba(249,115,22,0.2)" : "rgba(59,130,246,0.2)"};`}
              />
              {/* Sparkline */}
              <div class="absolute top-4 right-4 w-24 h-10 opacity-90 group-hover/stat:opacity-100 transition-opacity">
                <DitherSparkline
                  client:load
                  data={sparklineData[i].values}
                  color={sparklineData[i].color}
                />
              </div>
              <div>
                <p
                  class="stat-number text-2xl md:text-3xl font-semibold text-[color:var(--text)] tracking-tighter"
                  data-value={stat.value}
                >
                  {stat.value}
                </p>
                <p class="mt-2 text-[13px] font-medium text-[color:var(--text)] leading-snug pr-12 md:pr-24">
                  {stat.label}
                </p>
              </div>
              {/* Counter bar */}
              <div class="mt-3 h-[2px] rounded-full bg-[rgba(255,255,255,0.06)] overflow-hidden">
                <div
                  class="h-full rounded-full"
                  style={`background: ${stat.accent === "marketing" ? "var(--mkt)" : "var(--sw)"}; width: ${counterTargets[i + 1]}%;`}
                />
              </div>
              <p class="mt-3 text-[13px] muted leading-snug">{stat.sub}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
