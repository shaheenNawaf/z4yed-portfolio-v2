---
interface Props {
  id: string;
  title: string;
  company: string;
  date: string;
  location: string;
  description: string;
  color: string;
  details?: readonly string[];
  gallery?: readonly string[];
  video?: string;
}

const {
  id,
  title,
  company,
  date,
  location,
  description,
  color,
  details = [],
  video,
  gallery = [],
} = Astro.props;
---

<div
  id={`card-${id}`}
  class="bg-zinc-900/20 backdrop-blur-sm border border-zinc-800/50 rounded-2xl p-5 flex gap-4 cursor-pointer transition-[transform,border-color] duration-300 hover:border-zinc-700 hover:-translate-y-1 group"
  data-modal-id={id}
>
  <div
    class="w-10 h-10 rounded-full flex-shrink-0 flex items-center justify-center text-white font-bold"
    style={`background-color: ${color}`}
  >
    {company.charAt(0)}
  </div>
  <div class="flex-1">
    <h3
      class="text-sm font-semibold text-white group-hover:text-blue-400 transition-colors"
    >
      {title}
    </h3>
    <p class="text-xs text-zinc-500 mt-1 mb-3">{company} • {date}</p>
    <p class="text-sm text-zinc-400 line-clamp-2">{description}</p>
  </div>
</div>

<dialog
  id={id}
  class="fixed inset-0 m-auto bg-zinc-950/60 backdrop-blur-md border border-blue-500/10 rounded-3xl max-w-3xl w-[95%] focus:outline-none overflow-hidden"
>
  <div class="relative max-h-[90vh] overflow-y-auto">
    <button
      class="absolute top-4 right-4 text-zinc-400 hover:text-white close-modal z-50 bg-black/50 w-10 h-10 rounded-full flex items-center justify-center transition-colors"
      >✕</button
    >

    <div class="p-8">
      <div class="flex items-center gap-4 mb-6">
        <div
          class="w-14 h-14 rounded-full flex items-center justify-center text-xl font-bold text-white"
          style={`background-color: ${color}`}
        >
          {company.charAt(0)}
        </div>
        <div>
          <h2 class="text-2xl font-bold text-white leading-tight">{title}</h2>
          <p class="text-blue-500 font-medium">{company} — {location}</p>
          <p class="text-xs text-zinc-500 italic">{date}</p>
        </div>
      </div>

      <div class="space-y-6">
        <p
          class="text-base leading-relaxed text-zinc-300 italic border-l-4 border-blue-600 pl-4 bg-blue-600/5 py-2"
        >
          {description}
        </p>

        <div>
          <h4
            class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-4"
          >
            Key Achievements
          </h4>
          <ul class="space-y-4">
            {
              details.map((item: string) => (
                <li class="flex gap-3 text-sm text-zinc-400 leading-relaxed">
                  <span class="text-blue-500 mt-1">▹</span>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <br />

      {
        video && (
          <div class="w-full bg-black aspect-video">
            <iframe src={video} class="w-full h-full" allowfullscreen />
          </div>
        )
      }

      {
        gallery.length > 0 && (
          <div
            class={`grid gap-2 p-2 ${gallery.length === 1 ? "grid-cols-1" : "grid-cols-2"}`}
          >
            {gallery.map((img) => (
              <img
                src={img}
                alt="Experience highlight"
                class="w-full h-64 object-cover rounded-lg border border-zinc-800 hover:scale-[1.02] transition-transform cursor-zoom-in"
              />
            ))}
          </div>
        )
      }
    </div>
  </div>
</dialog>
