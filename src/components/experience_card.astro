---
import type { Category } from "../data/resume";

interface Props {
  id: string;
  category: Category;
  title: string;
  company: string;
  date: string;
  location: string;
  description: string;
  color: string;
  details?: readonly string[];
  gallery?: readonly string[];
  video?: string;
}

const {
  id,
  category,
  title,
  company,
  date,
  location,
  description,
  color,
  details = [],
  video,
  gallery = [],
} = Astro.props;
---

{
  /* ─── CARD ──────────────────────────────────────────────────────────────── */
}
<div
  id={`card-${id}`}
  class={`group bg-zinc-950/40 backdrop-blur-md border border-white/5 rounded-2xl p-6 flex gap-5 cursor-pointer transition-all duration-500 hover:-translate-y-1 shadow-xl ${category === "software" ? "hover:border-blue-500/50" : "hover:border-orange-500/50"}`}
  data-modal-id={id}
>
  <div
    class="w-11 h-11 rounded-xl flex-shrink-0 flex items-center justify-center text-white font-bold text-lg border border-white/10 shadow-lg"
    style={`background-color: ${color}`}
  >
    {company.charAt(0)}
  </div>
  <div class="flex-1 min-w-0">
    <h3
      class={`text-sm md:text-base font-semibold text-white transition-colors leading-tight ${category === "software" ? "group-hover:text-blue-400" : "group-hover:text-orange-400"}`}
    >
      {title}
    </h3>
    <p class="text-xs text-zinc-500 mt-1.5 mb-3">{company} • {date}</p>
    <p class="text-xs md:text-sm text-zinc-400 leading-relaxed line-clamp-2">
      {description}
    </p>
  </div>
</div>

{
  /* ─── DIALOG MODAL ──────────────────────────────────────────────────────── */
}
<dialog
  id={id}
  class={`fixed inset-0 m-auto bg-zinc-950/60 backdrop-blur-xl rounded-3xl max-w-3xl w-[95%] focus:outline-none overflow-hidden ${category === "software" ? "border border-blue-500/10 shadow-[0_0_50px_-12px_rgba(59,130,246,0.3)]" : "border border-orange-500/10 shadow-[0_0_50px_-12px_rgba(249,115,22,0.3)]"}`}
>
  <div class="relative max-h-[90vh] overflow-y-auto">
    <button
      class="close-modal absolute top-4 right-4 z-50 bg-black/60 hover:bg-black text-white w-10 h-10 rounded-full flex items-center justify-center transition-all border border-white/10"
    >
      ✕
    </button>

    <div class="p-8 md:p-12">
      {/* Header Block */}
      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 mb-10 pb-8 border-b border-zinc-800/50"
      >
        <div class="flex items-center gap-4">
          <div
            class="w-14 h-14 rounded-2xl flex items-center justify-center text-xl font-bold text-white border border-white/10 shadow-lg shrink-0"
            style={`background-color: ${color}`}
          >
            {company.charAt(0)}
          </div>
          <div>
            <h2
              class="text-2xl md:text-3xl font-semibold text-white leading-tight tracking-tight"
            >
              {title}
            </h2>
            <p
              class={`font-medium text-xs mt-1 uppercase tracking-wider ${category === "software" ? "text-blue-500" : "text-orange-500"}`}
            >
              {company} — <span
                class="text-zinc-500 lowercase first-letter:uppercase"
                >{location}</span
              >
            </p>
          </div>
        </div>

        {
          /* Standardized Inner Tenure Badge - matches other components precisely */
        }
        <div
          class={`p-4 rounded-2xl min-w-[140px] text-center border ${category === "software" ? "bg-blue-600/10 border-blue-500/20" : "bg-orange-500/10 border-orange-500/20"}`}
        >
          <span
            class={`text-[10px] font-bold uppercase block mb-1 tracking-widest ${category === "software" ? "text-blue-500/70" : "text-orange-500/70"}`}
          >
            Tenure
          </span>
          <span class="text-xl font-bold text-white">{date}</span>
        </div>
      </div>

      <div class="space-y-8">
        {
          /* Description Highlight Block - Aligned to standard background tint utilities */
        }
        <p
          class={`text-base leading-relaxed italic border-l-4 pl-4 py-3 rounded-r-xl ${category === "software" ? "border-blue-600 bg-blue-600/5" : "border-orange-500 bg-orange-500/5"}`}
        >
          {description}
        </p>

        {/* Key Achievements Bullet list */}
        <div>
          <h4
            class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500 mb-5"
          >
            Key Achievements & Responsibilities
          </h4>
          <ul class="space-y-4">
            {
              details.map((item: string) => (
                <li class="flex gap-3 text-sm text-zinc-400 leading-relaxed">
                  <span
                    class={`mt-1 font-bold ${category === "software" ? "text-blue-500" : "text-orange-500"}`}
                  >
                    ▹
                  </span>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>

        {/* Video Asset Section */}
        {
          video && (
            <div class="w-full bg-black aspect-video rounded-2xl overflow-hidden border border-zinc-800 shadow-2xl mt-8">
              <iframe src={video} class="w-full h-full" allowfullscreen />
            </div>
          )
        }

        {/* Protected Gallery Assets Section */}
        {
          gallery.length > 0 && (
            <div class="border-t border-zinc-800/50 pt-8 mt-8">
              <h4 class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-6">
                Supporting Assets & Evidence
              </h4>
              <div
                class={`grid gap-4 ${gallery.length === 1 ? "grid-cols-1" : "grid-cols-2"}`}
              >
                {gallery.map((img) => (
                  <div class="relative overflow-hidden rounded-xl border border-zinc-800 bg-zinc-950 group/img protected-image select-none">
                    <img
                      src={img}
                      alt="Experience highlight"
                      class="w-full h-64 object-cover transition-transform duration-700 group-hover/img:scale-105 cursor-zoom-in"
                    />

                    {/* SVG Watermark overlay */}
                    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none opacity-20">
                      <svg
                        class="w-3/4 h-auto"
                        viewBox="0 0 200 40"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <text
                          x="50%"
                          y="50%"
                          dominant-baseline="middle"
                          text-anchor="middle"
                          font-family="monospace"
                          font-size="7"
                          fill="#ffffff"
                          font-weight="bold"
                          letter-spacing="2"
                        >
                          property of shaheen al adwani
                        </text>
                      </svg>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </div>
  </div>
</dialog>
