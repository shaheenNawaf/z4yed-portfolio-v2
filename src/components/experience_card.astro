---
import type { Category } from "../data/resume";
import Watermark from "./watermark.astro";

interface Props {
  id: string;
  category: Category;
  title: string;
  company: string;
  date: string;
  location: string;
  description: string;
  color: string;
  details?: readonly string[];
  gallery?: readonly string[];
  video?: string;
}

const {
  id,
  category,
  title,
  company,
  date,
  location,
  description,
  color,
  details = [],
  video,
  gallery = [],
} = Astro.props;

const shadowClass =
  category === "software" ? "modal-shadow-software" : "modal-shadow-marketing";
---

<div
  id={`card-${id}`}
  class="group surface radius-card p-6 flex gap-5 cursor-pointer transition-all duration-500 hover:border-[color:var(--accent-border)] hover:-translate-y-1 shadow-xl"
  data-modal-id={id}
>
  <div
    class="w-11 h-11 rounded-xl flex-shrink-0 flex items-center justify-center text-white font-bold text-lg border hairline shadow-lg shrink-0"
    style={`background-color: ${color}`}
  >
    {company.charAt(0)}
  </div>
  <div class="flex-1 min-w-0">
    <h3
      class="text-sm md:text-base font-semibold text-[color:var(--text)] transition-colors leading-tight group-hover:text-[color:var(--accent)]"
    >
      {title}
    </h3>
    <p class="faint text-xs mt-1.5 mb-3">{company} • {date}</p>
    <p class="muted text-xs md:text-sm leading-relaxed line-clamp-2">
      {description}
    </p>
  </div>
</div>

<dialog
  id={id}
  class={`modal fixed inset-0 m-auto backdrop-blur-xl radius-card max-w-3xl w-[95%] focus:outline-none overflow-hidden ${shadowClass}`}
>
  <div class="relative max-h-[90dvh] overflow-y-auto">
    <button
      class="close-modal absolute top-4 right-4 z-50 w-10 h-10 rounded-full flex items-center justify-center transition-all border"
    >
      ✕
    </button>

    <div class="p-8 md:p-12">
      <div
        class="flex flex-col sm:flex-row sm:items-center justify-between gap-6 mb-10 pb-8 border-b hairline"
      >
        <div class="flex items-center gap-4">
          <div
            class="w-14 h-14 rounded-2xl flex items-center justify-center text-xl font-bold text-white border hairline shadow-lg shrink-0"
            style={`background-color: ${color}`}
          >
            {company.charAt(0)}
          </div>
          <div>
            <h2
              class="text-2xl md:text-3xl font-semibold text-[color:var(--text)] leading-tight tracking-tight"
            >
              {title}
            </h2>
            <p
              class="font-medium text-xs mt-1 uppercase tracking-wider text-[color:var(--accent)]"
            >
              {company} · <span class="faint lowercase first-letter:uppercase"
                >{location}</span
              >
            </p>
          </div>
        </div>

        <div
          class="p-4 rounded-2xl min-w-[140px] text-center border track-accent-bg"
        >
          <span
            class="text-[10px] font-bold uppercase block mb-1 tracking-widest text-[color:var(--accent)]/70"
          >
            Tenure
          </span>
          <span class="text-xl font-bold text-[color:var(--text)]">{date}</span>
        </div>
      </div>

      <div class="space-y-8">
        <p
          class="text-base leading-relaxed italic border-l-4 pl-4 py-3 rounded-r-xl track-accent-bg"
        >
          {description}
        </p>

        <div>
          <h4
            class="text-[10px] font-bold uppercase tracking-[0.2em] muted mb-5"
          >
            Key Achievements & Responsibilities
          </h4>
          <ul class="space-y-4">
            {
              details.map((item: string) => (
                <li class="flex gap-3 text-sm muted leading-relaxed">
                  <span class="mt-1 font-bold" style={`color: var(--accent)`}>
                    ▹
                  </span>
                  {item}
                </li>
              ))
            }
          </ul>
        </div>

        {
          video && (
            <div class="w-full bg-black aspect-video rounded-2xl overflow-hidden border hairline shadow-2xl mt-8">
              <iframe src={video} class="w-full h-full" allowfullscreen />
            </div>
          )
        }

        {
          gallery.length > 0 && (
            <div class="border-t hairline pt-8 mt-8">
              <h4 class="text-[10px] font-bold muted uppercase tracking-[0.2em] mb-6">
                Supporting Assets & Evidence
              </h4>
              <div
                class={`grid gap-4 ${gallery.length === 1 ? "grid-cols-1" : "grid-cols-2"}`}
              >
                {gallery.map((img) => (
                  <div class="relative overflow-hidden rounded-xl border hairline bg-[color:var(--card-bg-2)] group/img protected-image select-none">
                    <img
                      src={img}
                      alt="Experience highlight"
                      class="w-full h-64 object-cover transition-transform duration-700 group-hover/img:scale-105 cursor-zoom-in"
                    />
                    <Watermark />
                  </div>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </div>
  </div>
</dialog>
