---
import ThemeToggle from "./theme_toggle.astro";

interface Props {
  mode: "software" | "marketing";
}

const { mode } = Astro.props;
const otherHref = mode === "software" ? "/marketing" : "/software";
const otherLabel = mode === "software" ? "Studio" : "Lab";
const accentHover =
  mode === "software"
    ? "hover:text-blue-400 hover:border-blue-500/30"
    : "hover:text-orange-400 hover:border-orange-500/30";
---

<nav class="flex justify-between items-center w-full mb-6 md:mb-10 gap-3">
  <div class="flex items-center gap-2">
    <a
      href="/"
      class:list={[
        "inline-flex items-center gap-2 py-2 md:py-0 px-4 md:px-5 h-auto md:h-[48px] rounded-xl surface text-[color:var(--text-muted)] transition-all text-[10px] md:text-[11px] font-bold uppercase tracking-[0.15em] group shrink-0",
        accentHover,
      ]}
    >
      <svg class="w-3.5 h-3.5 transition-transform group-hover:-translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"></path>
      </svg>
      Hub
    </a>
    <a
      href={otherHref}
      class="hidden sm:inline-flex items-center py-2 px-4 h-auto md:h-[48px] rounded-xl surface text-[color:var(--text-faint)] hover:text-[color:var(--text)] hover:border-[color:var(--border-strong)] transition-all text-[10px] md:text-[11px] font-bold uppercase tracking-[0.15em]"
    >
      Switch to {otherLabel}
    </a>
  </div>
  <div class="flex items-center gap-2">
    <a
      href="#book-call"
      class="track-btn inline-flex items-center px-3 py-2 md:px-4 md:h-[48px] rounded-xl text-[10px] font-bold uppercase tracking-wider transition-all active:scale-95"
    >
      Book intro call
    </a>
    <ThemeToggle variant="inline" />
  </div>
</nav>
