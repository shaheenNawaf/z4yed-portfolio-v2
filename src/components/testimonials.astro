---
const placeholders = [
  {
    name: "{{Name}}",
    role: "{{Role}}",
    company: "{{Company}}",
    quote:
      "{{Placeholder quote about shipping production software and the growth systems behind it.}}",
  },
  {
    name: "{{Name}}",
    role: "{{Role}}",
    company: "{{Company}}",
    quote:
      "{{Placeholder quote about marketing impact, ROAS, and reliable execution.}}",
  },
  {
    name: "{{Name}}",
    role: "{{Role}}",
    company: "{{Company}}",
    quote:
      "{{Placeholder quote about cross-functional collaboration and ownership.}}",
  },
];
---

<section id="testimonials" class="relative py-16 md:py-24">
  <div class="max-w-5xl mx-auto px-5 md:px-8">
    <div class="flex items-center gap-3 mb-10">
      <h2
        class="font-grotesk text-sm font-bold uppercase tracking-[0.2em] text-[color:var(--text)]"
      >
        What collaborators say
      </h2>
      <div class="h-px flex-1 hairline"></div>
    </div>

    <div class="grid md:grid-cols-3 gap-4">
      {
        placeholders.map((t, i) => (
          <figure
            class="panel radius-card p-6 flex flex-col"
            style={`--card-accent: ${i % 2 === 0 ? "var(--mkt)" : "var(--sw)"}`}
          >
            <svg
              class="w-6 h-6 mb-4 opacity-60"
              style={`color: var(--card-accent)`}
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path d="M6 17h3l2-4V7H5v6h3l-2 4zm8 0h3l2-4V7h-6v6h3l-2 4z" />
            </svg>
            <blockquote class="text-[14px] muted leading-relaxed flex-1">
              {t.quote}
            </blockquote>
            <figcaption class="mt-5 pt-4 border-t hairline">
              <p class="text-[13px] font-semibold text-[color:var(--text)]">
                {t.name}
              </p>
              <p class="text-[11px] faint mt-0.5">
                {t.role}, {t.company}
              </p>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
