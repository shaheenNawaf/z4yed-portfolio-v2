---
interface Props {
  id: string;
  title: string;
  role: string;
  results?: string;
  deliverables?: readonly string[];
  description: string;
  media?: {
    type: "video" | "image";
    url: string;
    thumbnail?: string;
  };
  gallery?: readonly string[];
  color: string;
}

const {
  id,
  title,
  role,
  results,
  deliverables = [],
  description,
  media,
  gallery = [],
  color,
} = Astro.props;

const cardImage =
  media?.type === "video" && media.thumbnail ? media.thumbnail : media?.url;
---

<div
  class="group bg-zinc-950/40 backdrop-blur-md border border-white/5 rounded-2xl overflow-hidden cursor-pointer transition-all duration-500 hover:border-orange-500/50 hover:-translate-y-1 shadow-xl"
  data-modal-id={id}
>
  <div
    class="aspect-video w-full relative overflow-hidden"
    style={`background-color: ${color}18`}
  >
    {
      media?.type === "video" && (
        <div class="absolute inset-0 flex items-center justify-center bg-black/40 group-hover:bg-black/20 transition-colors z-10">
          <div class="w-12 h-12 flex items-center justify-center bg-orange-600 text-white rounded-full shadow-xl group-hover:scale-110 transition-transform">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </div>
      )
    }

    {
      cardImage ? (
        <img
          src={cardImage}
          alt={title}
          class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity duration-700"
        />
      ) : (
        <div class="absolute inset-0" style={`background-color: ${color}22`}>
          <div
            class="absolute inset-0 opacity-20"
            style="background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 20px 20px;"
          />
        </div>
      )
    }

    {
      results && (
        <div class="absolute top-4 left-4 z-20 bg-orange-600 text-white px-3 py-1 rounded-lg text-[10px] font-bold uppercase tracking-tighter shadow-2xl">
          {results}
        </div>
      )
    }
  </div>

  <!-- Card body -->
  <div class="p-6">
    <div class="mb-4">
      <h3
        class="text-lg font-semibold text-white group-hover:text-orange-400 transition-colors tracking-tight"
      >
        {title}
      </h3>
      <p
        class="text-orange-500 text-xs font-medium uppercase tracking-widest mt-1"
      >
        {role}
      </p>
    </div>

    <p class="text-sm text-zinc-400 line-clamp-2 mb-6 leading-relaxed">
      {description}
    </p>

    <div class="flex flex-wrap gap-2">
      {
        deliverables.map((item: string) => (
          <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest border border-zinc-800 px-2 py-1 rounded bg-zinc-950/50">
            {item}
          </span>
        ))
      }
    </div>
  </div>
</div>

<dialog
  id={id}
  class="fixed inset-0 m-auto bg-zinc-950/60 backdrop-blur-xl border border-orange-500/10 rounded-3xl max-w-3xl w-[95%] focus:outline-none overflow-hidden shadow-[0_0_50px_-12px_rgba(249,115,22,0.3)]"
>
  <div class="flex flex-col relative max-h-[90vh] overflow-y-auto">
    <button
      class="close-modal absolute top-4 right-4 z-50 bg-black/60 hover:bg-black text-white w-10 h-10 rounded-full flex items-center justify-center transition-all border border-white/10"
    >
      ✕
    </button>

    <div
      class={`w-full relative flex items-center justify-center shrink-0 border-b border-zinc-800 overflow-hidden ${media?.type === "video" ? "aspect-video" : "aspect-square"}`}
      style={`background-color: ${color}18`}
    >
      {
        media?.type === "video" ? (
          <video class="w-full h-full" controls playsinline preload="metadata">
            <source src={media.url} type="video/mp4" />
          </video>
        ) : media?.url ? (
          <img
            src={media.url}
            alt={title}
            class="w-full h-full object-contain"
          />
        ) : (
          <div class="absolute inset-0" style={`background-color: ${color}22`}>
            <div
              class="absolute inset-0 opacity-20"
              style="background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 24px 24px;"
            />
            <span class="absolute inset-0 flex items-center justify-center font-mono text-zinc-600 text-xs uppercase tracking-widest">
              No preview available
            </span>
          </div>
        )
      }
    </div>

    <div class="p-8 md:p-12">
      <div
        class="flex flex-col md:flex-row justify-between items-start gap-6 mb-10"
      >
        <div class="flex-1">
          <h2
            class="text-3xl md:text-4xl font-semibold text-white tracking-tighter mb-2 leading-tight"
          >
            {title}
          </h2>
          <p
            class="text-orange-500 font-bold uppercase tracking-[0.2em] text-xs"
          >
            {role}
          </p>
        </div>
        {
          results && (
            <div class="bg-orange-600/10 border border-orange-500/20 p-4 rounded-2xl min-w-[140px] text-center">
              <span class="text-[10px] text-orange-500/70 font-bold uppercase block mb-1 tracking-widest">
                Outcome
              </span>
              <span class="text-xl font-bold text-white">{results}</span>
            </div>
          )
        }
      </div>

      <div class="grid md:grid-cols-3 gap-10 mb-12">
        <div class="md:col-span-2">
          <h4
            class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-4"
          >
            Strategy & Execution
          </h4>
          <p class="text-base leading-relaxed text-zinc-400">
            {description}
          </p>
        </div>
        <div
          class="bg-zinc-950/50 p-6 rounded-2xl border border-zinc-800/50 h-fit"
        >
          <h4
            class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-4"
          >
            Deliverables
          </h4>
          <ul class="space-y-3">
            {
              deliverables.map((item: string) => (
                <li class="text-xs text-zinc-400 flex items-start gap-3">
                  <span class="w-1.5 h-1.5 bg-orange-500 rounded-full mt-1.5 shrink-0" />
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      {
        gallery.length > 0 && (
          <div class="border-t border-zinc-800 pt-10">
            <h4 class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-6">
              Campaign Assets
            </h4>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
              {gallery.map((img) => (
                <div class="aspect-square rounded-xl overflow-hidden border border-zinc-800 bg-zinc-950 group/img">
                  <img
                    src={img}
                    alt="Campaign asset"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover/img:scale-110"
                  />
                </div>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </div>
</dialog>
