---
/**
 * Reusable SVG watermark overlay ("PROPERTY OF SHAHEEN AL ADWANI").
 * Renders an absolutely-positioned, pointer-events-none layer to drop inside
 * any image container.
 */
---

<div
  class="absolute inset-0 flex items-center justify-center pointer-events-none select-none opacity-20"
  aria-hidden="true"
>
  <svg
    class="w-3/4 h-auto"
    viewBox="0 0 200 40"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <text
      x="50%"
      y="50%"
      dominant-baseline="middle"
      text-anchor="middle"
      font-family="monospace"
      font-size="7"
      fill="#ffffff"
      font-weight="bold"
      letter-spacing="2"
    >
      property of shaheen al adwani
    </text>
  </svg>
</div>
