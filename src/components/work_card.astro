---
import Watermark from "./watermark.astro";

interface Props {
  id: string;
  title: string;
  date: string;
  role: string;
  color: string;
  description: string;
  mode: "software" | "marketing";
  tags?: readonly string[];
  deliverables?: readonly string[];
  results?: string;
  liveUrl?: string;
  repoUrl?: string;
  media?: { type: "video" | "image"; url: string; thumbnail?: string };
  gallery?: readonly string[];
}

const {
  id,
  title,
  date,
  role,
  color,
  description,
  mode,
  tags = [],
  deliverables = [],
  results,
  liveUrl,
  repoUrl,
  media,
  gallery = [],
} = Astro.props;

const cardImage =
  media?.type === "video" && media.thumbnail ? media.thumbnail : media?.url;
const fallBackImage = `https://picsum.photos/seed/${id}/800/600`;
const badge = results ?? date;
const listItems = mode === "software" ? tags : deliverables;
const listHeading = mode === "software" ? "Stack & Tags" : "Deliverables";
const overviewHeading = mode === "software" ? "Project Overview" : "Strategy & Execution";
const shadowClass =
  mode === "software" ? "modal-shadow-software" : "modal-shadow-marketing";
---

<div
  class="group surface radius-card overflow-hidden cursor-pointer transition-all duration-500 hover:border-[color:var(--accent-border)] hover:-translate-y-1 shadow-xl"
  data-modal-id={id}
>
  <div
    class="aspect-video w-full relative overflow-hidden"
    style={`background-color: ${color}18`}
  >
    {
      media?.type === "video" && (
        <div class="absolute inset-0 flex items-center justify-center bg-black/40 group-hover:bg-black/20 transition-colors z-10">
          <div
            class="w-12 h-12 flex items-center justify-center rounded-full shadow-xl group-hover:scale-110 transition-transform text-white"
            style={`background-color: var(--accent)`}
          >
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </div>
      )
    }

    {
      cardImage ? (
        <div class="relative w-full h-full overflow-hidden protected-image select-none">
          <img
            src={cardImage}
            alt={title}
            class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity duration-700"
          />
          <Watermark />
        </div>
      ) : (
        <div class="absolute inset-0">
          <img
            src={fallBackImage}
            alt={title}
            class="w-full h-full object-cover opacity-50 group-hover:opacity-80 transition-opacity duration-700"
          />
          <div
            class="absolute inset-0 opacity-20"
 style="background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 20px 20px;"
          />
        </div>
      )
    }

    {
      badge && (
        <div
          class="absolute top-4 left-4 z-20 text-white px-3 py-1 rounded-lg text-[10px] font-bold uppercase tracking-tighter shadow-2xl"
          style={`background-color: var(--accent)`}
        >
          {badge}
        </div>
      )
    }
  </div>

  <div class="p-6">
    <div class="mb-4">
      <h3
        class="text-lg font-semibold text-[color:var(--text)] group-hover:text-[color:var(--accent)] transition-colors tracking-tight"
      >
        {title}
      </h3>
      <p
        class="text-[color:var(--accent)] text-xs font-medium uppercase tracking-widest mt-1"
      >
        {role}
      </p>
    </div>

    <p class="muted text-sm line-clamp-2 mb-6 leading-relaxed">
      {description}
    </p>

    <div class="flex flex-wrap gap-2">
      {
        listItems.map((item: string) => (
          <span class="text-[10px] font-bold muted uppercase tracking-widest border hairline px-2 py-1 rounded bg-[color:var(--card-bg-2)]">
            {item}
          </span>
        ))
      }
    </div>
  </div>
</div>

<dialog
  id={id}
  class={`modal fixed inset-0 m-auto backdrop-blur-xl radius-card max-w-3xl w-[95%] focus:outline-none overflow-hidden ${shadowClass}`}
>
  <div class="flex flex-col relative max-h-[90dvh] overflow-y-auto">
    <button
      class="close-modal absolute top-4 right-4 z-50 w-10 h-10 rounded-full flex items-center justify-center transition-all border"
    >
      ✕
    </button>

    <div
      class:list={[
        "w-full relative flex items-center justify-center shrink-0 border-b hairline overflow-hidden",
        media?.type === "video" ? "aspect-video" : "aspect-square",
      ]}
      style={`background-color: ${color}18`}
    >
      {
        media?.type === "video" ? (
          <video class="w-full h-full" controls playsinline preload="metadata">
            <source src={media.url} type="video/mp4" />
          </video>
        ) : media?.url ? (
          <div class="relative w-full h-full overflow-hidden protected-image select-none">
            <img src={media.url} alt={title} class="w-full h-full object-contain" />
            <Watermark />
          </div>
        ) : (
          <div class="absolute inset-0">
            <img
              src={fallBackImage}
              alt={title}
              class="w-full h-full object-cover opacity-70"
            />
            <div
              class="absolute inset-0 opacity-20"
              style="background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 24px 24px;"
            />
          </div>
        )
      }
    </div>

    <div class="p-8 md:p-12">
      <div
        class="flex flex-col md:flex-row justify-between items-start gap-6 mb-10"
      >
        <div class="flex-1">
          <h2
            class="text-3xl md:text-4xl font-semibold text-[color:var(--text)] tracking-tighter mb-2 leading-tight"
          >
            {title}
          </h2>
          <p
            class="text-[color:var(--accent)] font-bold uppercase tracking-[0.2em] text-xs"
          >
            {role}
          </p>
        </div>
        {
          results && (
            <div
              class="p-4 rounded-2xl min-w-[140px] text-center border track-accent-bg"
            >
              <span
                class="text-[10px] font-bold uppercase block mb-1 tracking-widest text-[color:var(--accent)]/70"
              >
                Outcome
              </span>
              <span class="text-xl font-bold text-[color:var(--text)]">{results}</span>
            </div>
          )
        }
      </div>

      <div class="grid md:grid-cols-3 gap-10 mb-12">
        <div class="md:col-span-2">
          <h4
            class="text-[10px] font-bold uppercase tracking-[0.2em] muted mb-4"
          >
            {overviewHeading}
          </h4>
          <p class="text-base leading-relaxed muted">{description}</p>
        </div>
        <div
          class="p-6 rounded-2xl border hairline h-fit bg-[color:var(--card-bg-2)]"
        >
          <h4
            class="text-[10px] font-bold uppercase tracking-[0.2em] muted mb-4"
          >
            {listHeading}
          </h4>
          <ul class="space-y-3">
            {
              listItems.map((item: string) => (
                <li class="text-xs muted flex items-start gap-3">
                  <span
                    class="mt-1.5 w-1.5 h-1.5 rounded-full shrink-0"
                    style={`background-color: var(--accent)`}
                  />
                  {item}
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      {
        mode === "software" && (liveUrl || repoUrl) && (
          <div class="border-t hairline pt-8 flex flex-wrap gap-3">
            {liveUrl && liveUrl.length > 0 && (
              <a
                href={liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-semibold transition-all active:scale-95 text-white"
                style={`background-color: var(--accent)`}
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Visit Live Site
              </a>
            )}
            {repoUrl && repoUrl.length > 0 && (
              <a
                href={repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-2.5 bg-[color:var(--card-bg-2)] hover:border-[color:var(--border-strong)] text-[color:var(--text)] rounded-xl text-sm font-semibold transition-colors active:scale-95 border hairline"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                </svg>
                View Code
              </a>
            )}
          </div>
        )
      }

      {
        mode === "marketing" && gallery.length > 0 && (
          <div class="border-t hairline pt-10">
            <h4 class="text-[10px] font-bold muted uppercase tracking-[0.2em] mb-6">
              Campaign Assets
            </h4>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
              {gallery.map((img) => (
                <div class="aspect-square rounded-xl overflow-hidden border hairline bg-[color:var(--card-bg-2)] group/img protected-image relative select-none">
                  <img
                    src={img}
                    alt="Campaign asset"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover/img:scale-110"
                  />
                  <Watermark />
                </div>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </div>
</dialog>
