---
import ThemeToggle from "./theme_toggle.astro";
import { name } from "../data/resume";
import { DitherAvatar } from "./dither-kit/avatar";

const navLinks = [
  { href: "/#work", label: "Projects" },
  { href: "/#experience", label: "Experience" },
  { href: "/#skills", label: "Skills" },
];

// const firstName = name.split(" ")[0];
---

<!-- ═══════════════════════════════════════════════════════════════════════════
     NAVBAR — confident minimal
     Flat text links, monogram + name logo, primary "Book a Call" CTA.
     --np (0→1) drives glass opacity interpolation (hero → companion).
     ═══════════════════════════════════════════════════════════════════════════ -->
<header id="site-nav" data-nav-state="hero" aria-label="Primary navigation">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label={`${name} - home`}>
      <span class="nav-monogram" aria-hidden="true">
        <DitherAvatar
          client:load
          name={name}
          hue={230}
          size={24}
          animate={true}
        />
      </span>
      <span class="nav-wordmark">{name}</span>
    </a>

    <nav class="nav-links" aria-label="Section navigation">
      {
        navLinks.map((l) => (
          <a href={l.href} class="nav-link">
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="nav-actions">
      <button
        id="mobile-menu-toggle"
        class="nav-icon-btn nav-mobile-toggle"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
      >
        <span class="mobile-toggle-icon" aria-hidden="true">
          <span class="mobile-toggle-line"></span>
          <span class="mobile-toggle-line"></span>
          <span class="mobile-toggle-line"></span>
        </span>
      </button>

      <span class="nav-theme">
        <ThemeToggle variant="inline" />
      </span>

      <a href="/#contact" class="nav-cta">
        <span>Book a Call</span>
        <svg
          class="nav-cta-arrow"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M3 8H13M13 8L8 3M13 8L8 13"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </a>
    </div>

    <div class="nav-progress-track">
      <div class="nav-progress-bar"></div>
    </div>
  </div>
</header>

<!-- Mobile full-screen overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-[60] flex flex-col opacity-0 pointer-events-none transition-all duration-300 lg:hidden"
  style="background-color: var(--bg);"
  role="dialog"
  aria-modal="true"
  aria-label="Navigation menu"
>
  <div class="flex items-center justify-between px-5 min-h-[64px] shrink-0">
    <a href="/" class="nav-logo" aria-label={`${name} - home`}>
      <span class="nav-monogram" aria-hidden="true">
        <DitherAvatar
          client:load
          name="name"
          hue={230}
          size={24}
          animate={true}
        />
      </span>
      <span class="nav-wordmark">{name}</span>
    </a>
    <div class="flex items-center gap-2">
      <ThemeToggle variant="inline" />
      <button
        id="mobile-menu-close"
        class="nav-icon-btn"
        aria-label="Close menu"
        type="button"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    class="flex-1 flex flex-col items-center justify-center -mt-16 gap-1 px-5"
  >
    {
      navLinks.map((l) => (
        <a
          href={l.href}
          class="mobile-link text-2xl md:text-3xl font-semibold text-[color:var(--text)] py-2 transition-all hover:opacity-50"
        >
          {l.label}
        </a>
      ))
    }
  </div>
</div>

<script>
  (() => {
    const init = () => {
      const navEl = document.getElementById("site-nav");
      if (!navEl) return;
      const nav = navEl;
      const hero = document.getElementById("hero");

      let ticking = false;

      const easeOutCubic = (t: number) => 1 - (1 - t) ** 3;

      function updateProgress() {
        const scrollY = window.scrollY;

        if (hero) {
          const heroHeight = hero.offsetHeight;
          const raw = Math.min(1, Math.max(0, scrollY / (heroHeight * 0.5)));
          const eased = easeOutCubic(raw);
          nav.style.setProperty("--np", String(eased.toFixed(4)));
        }

        const maxScroll =
          document.documentElement.scrollHeight - window.innerHeight;
        const scrollPercent =
          maxScroll > 0 ? Math.min(1, scrollY / maxScroll) : 0;
        nav.style.setProperty(
          "--scroll-progress",
          String(scrollPercent.toFixed(4)),
        );
      }

      if (hero) {
        const heroIo = new IntersectionObserver(
          ([entry]) => {
            if (entry.intersectionRatio < 0.25 && !entry.isIntersecting) {
              nav.setAttribute("data-nav-state", "companion");
            } else if (
              entry.isIntersecting ||
              entry.intersectionRatio >= 0.25
            ) {
              nav.setAttribute("data-nav-state", "hero");
            }
          },
          { threshold: [0, 0.25] },
        );
        heroIo.observe(hero);
      }

      function onScroll() {
        if (!ticking) {
          requestAnimationFrame(() => {
            updateProgress();
            ticking = false;
          });
          ticking = true;
        }
      }

      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener(
        "resize",
        () => requestAnimationFrame(updateProgress),
        { passive: true },
      );
      updateProgress();

      /* ═══════════════════════════════════════════════════════════════
         MOBILE FULL-SCREEN OVERLAY
         ═══════════════════════════════════════════════════════════════ */
      const toggle = document.getElementById(
        "mobile-menu-toggle",
      ) as HTMLButtonElement | null;
      const menu = document.getElementById("mobile-menu");
      const closeBtn = document.getElementById("mobile-menu-close");
      let lastFocusedElement: Element | null = null;

      const focusableSelector =
        'a[href], button, input, textarea, select, [tabindex]:not([tabindex="-1"])';

      const trapFocus = (e: KeyboardEvent) => {
        if (e.key !== "Tab" || !menu) return;
        const focusables = Array.from(
          menu.querySelectorAll(focusableSelector),
        ) as HTMLElement[];
        if (focusables.length === 0) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      };

      const open = () => {
        if (!menu || !toggle) return;
        lastFocusedElement = document.activeElement;
        menu.classList.add("is-open");
        toggle.classList.add("is-active");
        toggle.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
        document.body.classList.add("mobile-menu-open");
        const closeButton = menu.querySelector(
          "#mobile-menu-close",
        ) as HTMLElement | null;
        (closeButton || menu.querySelector("a"))?.focus();
        menu.addEventListener("keydown", trapFocus);
      };

      const close = () => {
        if (!menu || !toggle) return;
        menu.classList.remove("is-open");
        toggle.classList.remove("is-active");
        toggle.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
        document.body.classList.remove("mobile-menu-open");
        menu.removeEventListener("keydown", trapFocus);
        if (lastFocusedElement && "focus" in lastFocusedElement) {
          (lastFocusedElement as HTMLElement).focus();
        }
      };

      if (toggle && menu) {
        toggle.addEventListener("click", () => {
          const isOpen = menu.classList.contains("is-open");
          isOpen ? close() : open();
        });
        if (closeBtn) closeBtn.addEventListener("click", close);
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") close();
        });

        menu.querySelectorAll("a").forEach((a) => {
          a.addEventListener("click", close);
        });

        menu.addEventListener("click", (e) => {
          if (e.target === menu) close();
        });
      }
    };

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
    document.addEventListener("astro:after-swap", () => {
      document.body.classList.remove("mobile-menu-open");
      init();
    });
  })();
</script>

<style>
  /* ═══════════════════════════════════════════════════════════════════════════
     NAVBAR — confident minimal
     Full-width bar with hairline border-bottom, strong glass effect.
     --np drives glass opacity (0 = hero, 1 = companion).
     ═══════════════════════════════════════════════════════════════════════════ */

  /* ── Header ── */
  #site-nav {
    --np: 0;
    --scroll-progress: 0;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    height: 64px;
    background-color: color-mix(
      in srgb,
      var(--bg) calc(60% + 20% * var(--np)),
      transparent
    );
    backdrop-filter: blur(20px) saturate(150%);
    -webkit-backdrop-filter: blur(20px) saturate(150%);
    border-bottom: 1px solid
      color-mix(in srgb, var(--border) calc(50% + 50% * var(--np)), transparent);
  }

  /* Subtle noise texture on glass */
  #site-nav::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.7' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    background-size: 128px 128px;
    opacity: calc(0.5 + 0.5 * var(--np));
    pointer-events: none;
  }

  /* Top rim highlight */
  #site-nav::after {
    content: "";
    position: absolute;
    top: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, #fff 8%, transparent) 50%,
      transparent
    );
    pointer-events: none;
    opacity: calc(0.4 + 0.6 * var(--np));
  }

  html.light #site-nav::after {
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, #000 6%, transparent) 50%,
      transparent
    );
  }

  /* ── Nav inner ── */
  .nav-inner {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media (min-width: 768px) {
    .nav-inner {
      padding: 0 32px;
    }
  }

  /* ── Logo ── */
  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--text);
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity 150ms ease;
  }
  .nav-logo:hover {
    opacity: 0.8;
  }

  .nav-monogram {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 4px;
    overflow: hidden;
    flex-shrink: 0;
    transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-logo:hover .nav-monogram {
    transform: rotate(45deg) scale(1.05);
  }

  .nav-wordmark {
    font-weight: 700;
    font-size: 16px;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  /* ── Nav links (flat text, center) ── */
  .nav-links {
    display: none;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    align-items: center;
    gap: 4px;
  }
  @media (min-width: 64rem) {
    .nav-links {
      display: flex;
    }
  }

  .nav-link {
    position: relative;
    padding: 8px 14px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    border-radius: 8px;
    transition:
      color 150ms ease,
      background-color 150ms ease;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 4px;
    left: 50%;
    width: 0;
    height: 1.5px;
    background-color: var(--accent);
    transform: translateX(-50%);
    transition: width 200ms cubic-bezier(0.16, 1, 0.3, 1);
    border-radius: 1px;
  }
  .nav-link:hover {
    color: var(--text);
  }
  .nav-link:hover::after,
  .nav-link.is-active::after {
    width: calc(100% - 28px);
  }
  .nav-link.is-active {
    color: var(--text);
  }

  /* ── Actions (right) ── */
  .nav-actions {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .nav-icon-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background-color: transparent;
    border: 1px solid transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition:
      color 150ms ease,
      background-color 150ms ease,
      border-color 150ms ease;
  }
  .nav-icon-btn:hover {
    color: var(--text);
    background-color: var(--card-bg);
    border-color: var(--border);
  }

  /* Mobile toggle: hidden on desktop, visible on mobile */
  @media (min-width: 64rem) {
    .nav-mobile-toggle {
      display: none !important;
    }
  }

  .nav-theme {
    display: inline-flex;
  }
  /* Make the theme toggle button match .nav-icon-btn sizing */
  .nav-theme :global(#theme-toggle) {
    width: 40px;
    height: 40px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    border: 1px solid transparent;
    background-color: transparent;
    transition:
      filter 150ms ease,
      transform 150ms ease,
      color 150ms ease,
      background-color 150ms ease,
      border-color 150ms ease;
  }
  .nav-theme :global(#theme-toggle:hover) {
    color: var(--text);
    background-color: var(--card-bg);
    border-color: var(--border);
    filter: brightness(1.1);
    transform: translateY(-1px);
  }
  .nav-theme :global(#theme-toggle:active) {
    transform: translateY(0);
  }

  /* Overlay theme toggle: match nav-icon-btn sizing */
  #mobile-menu :global(#theme-toggle) {
    width: 40px;
    height: 40px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    border: 1px solid transparent;
    background-color: transparent;
  }
  #mobile-menu :global(#theme-toggle:hover) {
    color: var(--text);
    background-color: var(--card-bg);
    border-color: var(--border);
  }

  /* ── Primary CTA ── */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    margin-left: 4px;
    background-color: var(--accent);
    color: #fff;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition:
      filter 150ms ease,
      transform 150ms ease,
      box-shadow 200ms ease;
  }
  .nav-cta:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
    box-shadow: 0 8px 20px -8px var(--accent);
  }
  .nav-cta:active {
    transform: translateY(0);
  }
  .nav-cta-arrow {
    width: 12px;
    height: 12px;
    transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-cta:hover .nav-cta-arrow {
    transform: translateX(2px);
  }

  @media (max-width: 63.99rem) {
    .nav-cta,
    .nav-theme {
      display: none;
    }
  }

  /* ── Progress bar ── */
  .nav-progress-track {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 1.5px;
    background: transparent;
    pointer-events: none;
    overflow: hidden;
  }
  .nav-progress-bar {
    height: 100%;
    width: calc(var(--scroll-progress) * 100%);
    background: linear-gradient(90deg, var(--mkt), var(--sw));
    box-shadow: 0 0 8px color-mix(in srgb, var(--accent) 50%, transparent);
  }

  /* ── Mobile toggle icon (hamburger → X) ── */
  .mobile-toggle-icon {
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 14px;
    height: 14px;
    gap: 3px;
  }
  .mobile-toggle-line {
    display: block;
    width: 100%;
    height: 1.5px;
    background-color: currentColor;
    border-radius: 1px;
    transition:
      transform 200ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 150ms ease;
    transform-origin: center;
  }
  #mobile-menu-toggle.is-active .mobile-toggle-line:nth-child(1) {
    transform: translateY(4.5px) rotate(45deg);
  }
  #mobile-menu-toggle.is-active .mobile-toggle-line:nth-child(2) {
    opacity: 0;
  }
  #mobile-menu-toggle.is-active .mobile-toggle-line:nth-child(3) {
    transform: translateY(-4.5px) rotate(-45deg);
  }

  /* ── Mobile full-screen overlay ── */
  #mobile-menu {
    transform: scale(0.97);
  }
  #mobile-menu.is-open {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1);
  }
  #mobile-menu.is-open #mobile-menu-close {
    background-color: color-mix(in srgb, var(--card-bg) 80%, transparent);
    border-color: var(--border);
    color: var(--text);
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .nav-progress-track {
      transition: none !important;
    }
    .nav-logo,
    .nav-monogram,
    .nav-link::after,
    .nav-cta,
    .nav-cta-arrow,
    .mobile-toggle-line {
      transition: none !important;
    }
    .nav-logo:hover .nav-monogram {
      transform: none;
    }
    .nav-cta:hover .nav-cta-arrow {
      transform: none;
    }
  }
</style>
