---

<section id="skills" class="relative py-16 md:py-32">
  <div class="max-w-6xl mx-auto px-5 md:px-8">
    <div class="mb-10 md:mb-16">
      <h2
        class="text-3xl md:text-4xl font-bold text-[color:var(--text)] tracking-tight"
      >
        Skills
      </h2>
      <p class="mt-3 text-base md:text-lg muted max-w-2xl">
        Engineering depth and marketing execution, with the tools that back
        both.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-5 md:gap-6">
      <div
        class="skill-card surface radius-card p-6 md:p-8 transition-all duration-200 hover:border-[color:var(--card-accent)]"
        style="--card-accent: var(--sw);"
      >
        <div class="skill-card-header">
          <div class="skill-icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M8 7l-5 5 5 5"></path>
              <path d="M16 7l5 5-5 5"></path>
              <path d="M13 5l-2 14"></path>
            </svg>
          </div>
          <h3 class="skill-title">Engineering</h3>
        </div>
        <div class="skill-divider" aria-hidden="true"></div>
        <dl class="skill-categories">
          {
            Object.entries(eng).map(([group, items]) => (
              <div class="skill-category">
                <dt class="skill-category-label">{group}</dt>
                <dd class="skill-chip-row">
                  {items.map((skill) => (
                    <span class="skill-chip">
                      {skillIcons[skill] && (
                        <span class="skill-chip-icon" aria-hidden="true" set:html={skillIcons[skill]} />
                      )}
                      {skill}
                    </span>
                  ))}
                </dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div
        class="skill-card surface radius-card p-6 md:p-8 transition-all duration-200 hover:border-[color:var(--card-accent)]"
        style="--card-accent: var(--mkt);"
      >
        <div class="skill-card-header">
          <div class="skill-icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M3 17h4l4-5 3 3 6-8"></path>
              <path d="M17 7h6v6"></path>
            </svg>
          </div>
          <h3 class="skill-title">Marketing</h3>
        </div>
        <div class="skill-divider" aria-hidden="true"></div>
        <dl class="skill-categories">
          {
            Object.entries(mkt).map(([group, items]) => (
              <div class="skill-category">
                <dt class="skill-category-label">{group}</dt>
                <dd class="skill-chip-row">
                  {items.map((skill) => (
                    <span class="skill-chip">
                      {skillIcons[skill] && (
                        <span class="skill-chip-icon" aria-hidden="true" set:html={skillIcons[skill]} />
                      )}
                      {skill}
                    </span>
                  ))}
                </dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </div>
</section>

<style>
  .skill-card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .skill-icon {
    position: relative;
    width: 60px;
    height: 60px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background-image:
      radial-gradient(
        circle at 28% 22%,
        rgba(255, 255, 255, 0.16) 0%,
        transparent 48%
      ),
      linear-gradient(
        145deg,
        color-mix(in srgb, var(--card-accent) 14%, transparent),
        color-mix(in srgb, var(--card-accent) 8%, transparent)
      );
    border: 1px solid color-mix(in srgb, var(--card-accent) 40%, transparent);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.11),
      0 14px 32px -10px color-mix(in srgb, var(--card-accent) 34%, transparent),
      0 4px 12px -4px rgba(0, 0, 0, 0.25);
    transition:
      transform 0.25s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  .skill-icon svg {
    width: 26px;
    height: 26px;
    color: var(--card-accent);
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .skill-card:hover .skill-icon {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--card-accent) 65%, transparent);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.15),
      0 18px 40px -10px color-mix(in srgb, var(--card-accent) 44%, transparent),
      0 6px 16px -4px rgba(0, 0, 0, 0.3);
  }

  .skill-card:hover .skill-icon svg {
    transform: scale(1.03);
  }

  .skill-title {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--text);
    transition: color 0.25s ease;
  }

  .skill-card:hover .skill-title {
    color: color-mix(in srgb, var(--text) 92%, var(--card-accent));
  }

  .skill-divider {
    height: 1px;
    width: 100%;
    border: none;
    margin: 1.75rem 0;
    opacity: 0.5;
    background: linear-gradient(
      90deg,
      transparent 0%,
      color-mix(in srgb, var(--card-accent) 55%, transparent) 25%,
      color-mix(in srgb, var(--card-accent) 35%, transparent) 75%,
      transparent 100%
    );
    box-shadow: 0 0 14px color-mix(in srgb, var(--card-accent) 20%, transparent);
    transition: opacity 0.25s ease;
  }

  .skill-card:hover .skill-divider {
    opacity: 0.85;
  }

  .skill-categories {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .skill-category-label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .skill-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .skill-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--card-bg);
    transition: background-color 150ms ease, border-color 150ms ease;
  }

  @media (hover: hover) {
    .skill-chip:hover {
      background-color: color-mix(in srgb, var(--card-accent) 10%, transparent);
      border-color: color-mix(in srgb, var(--card-accent) 30%, transparent);
    }
  }

  .skill-chip-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    opacity: 0.85;
    transition: transform 0.25s ease, filter 0.25s ease;
  }

  .skill-chip-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .skill-chip:hover .skill-chip-icon {
    transform: scale(1.05);
    filter: brightness(1.15);
  }

  @media (prefers-reduced-motion: reduce) {
    .skill-icon,
    .skill-icon svg,
    .skill-title,
    .skill-divider,
    .skill-chip-icon {
      transition: none !important;
    }

    .skill-card:hover .skill-icon,
    .skill-card:hover .skill-icon svg,
    .skill-chip:hover .skill-chip-icon {
      transform: none;
      filter: none;
    }
  }
</style>
