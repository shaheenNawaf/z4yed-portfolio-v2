---
const { activeView } = Astro.props;
---
<div class="flex p-1 bg-zinc-900/50 border border-zinc-800 rounded-xl w-fit mb-8">
  <a 
    href="/" 
    class={`px-6 py-2 rounded-lg text-sm font-medium transition-all ${activeView === 'software' ? 'bg-blue-600 text-white shadow-lg' : 'text-zinc-500 hover:text-zinc-300'}`}
  >
    Software Engineering
  </a>
  <a 
    href="/marketing" 
    class={`px-6 py-2 rounded-lg text-sm font-medium transition-all ${activeView === 'marketing' ? 'bg-orange-600 text-white shadow-lg' : 'text-zinc-500 hover:text-zinc-300'}`}
  >
    Creator Partnerships
  </a>
</div>