---
const stats = [
  {
    headline: "2 live SaaS products",
    support: "designed, built, and shipped end-to-end.",
  },
  {
    headline: "$355K+ generated · 4:1 ROAS · 22K community",
    support: "real campaigns, not just dashboards.",
  },
  {
    headline: "One owner. No gap. More momentum.",
    support: "no handoff between strategy and execution.",
  },
];
---

<section id="why" class="relative py-16 md:py-32">
  <div class="max-w-6xl mx-auto px-5 md:px-8">
    <div class="mb-10 md:mb-14">
      <h2
        class="text-3xl md:text-4xl font-bold text-[color:var(--text)] tracking-tight"
      >
        Why hire one person who does both
      </h2>
      <p class="mt-3 text-base md:text-lg muted max-w-2xl">
        Engineering and marketing are usually separate hires. I'm neither. I'm both.
      </p>
    </div>

    <div class="why-container p-8 px-5 md:p-14">
      <div
        class="grid md:grid-cols-[1fr_auto_1fr] gap-8 md:gap-14 items-start"
      >
        <div class="flex flex-col gap-4 md:gap-8">
          <p
            class="text-3xl md:text-[2.25rem] font-bold text-[color:var(--text)] tracking-tight leading-[1.1]"
          >
            I bridge
            <span class="why-highlight why-highlight--engineering"
              >engineering</span
            >
            and
            <span class="why-highlight why-highlight--growth">growth</span>.
          </p>
          <p
            class="text-base md:text-lg font-medium text-[color:var(--text-faint)] tracking-[0.04em]"
          >
            Idea → Code → Launch → Scale.
          </p>
        </div>

        <div class="why-divider" aria-hidden="true"></div>

        <div class="flex flex-col gap-6">
          {
            stats.map((stat, i) => (
              <>
                <div class="why-stat">
                  <div class="flex items-start gap-3">
                    <span
                      class="why-stat-bullet mt-2"
                      aria-hidden="true"
                    />
                    <div>
                      <h3 class="text-base md:text-lg font-bold text-[color:var(--text)] leading-snug">
                        {stat.headline}
                      </h3>
                      <p class="mt-1 text-sm text-[color:var(--text-muted)] leading-relaxed">
                        {stat.support}
                      </p>
                    </div>
                  </div>
                </div>
                {i < stats.length - 1 && (
                  <div class="why-stat-divider hidden md:block" aria-hidden="true" />
                )}
              </>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .why-container {
    position: relative;
    border-radius: 1.5rem;
    background-color: color-mix(in srgb, var(--card-bg) 60%, transparent);
    border: 1px solid color-mix(in srgb, var(--accent) 22%, var(--border));
    box-shadow:
      0 0 48px -16px color-mix(in srgb, var(--accent) 10%, transparent),
      0 8px 32px -16px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .why-divider {
    display: none;
  }

  @media (min-width: 768px) {
    .why-divider {
      display: block;
      width: 1px;
      align-self: stretch;
      background: linear-gradient(
        to bottom,
        transparent,
        color-mix(in srgb, var(--accent) 24%, transparent) 40%,
        color-mix(in srgb, var(--accent) 24%, transparent) 60%,
        transparent
      );
    }
  }

  .why-highlight {
    font-weight: 700;
  }

  .why-highlight--engineering {
    color: var(--sw);
  }

  .why-highlight--growth {
    color: var(--mkt);
  }

  .why-stat-bullet {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background-color: var(--accent);
    flex-shrink: 0;
  }

  .why-stat-divider {
    height: 1px;
    width: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, var(--accent) 18%, transparent),
      transparent
    );
  }

  @media (prefers-reduced-motion: reduce) {
    .why-container {
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }
  }
</style>
