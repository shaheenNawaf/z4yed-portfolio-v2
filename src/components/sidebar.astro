---
import {
  name,
  pronouns,
  shortBio,
  contact,
  softwareSkills,
  marketingSkills,
} from "../data/resume";

interface Props {
  mode?: "software" | "marketing" | "all";
}
const { mode = "all" } = Astro.props;
---

<aside
  class="md:w-80 flex-shrink-0 flex flex-col gap-8 md:sticky md:top-20 h-fit"
>
  <div>
    <img
      src={contact.profileImage}
      alt={name}
      class="w-16 h-16 rounded-full mb-4 object-cover border border-zinc-800"
    />
    <h1 class="text-2xl font-bold text-white flex items-center gap-2">
      {name}
      <svg class="w-5 h-5 text-blue-500" fill="currentColor" viewBox="0 0 24 24"
        ><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
      >
    </h1>
    <p class="text-zinc-500 text-sm">{pronouns}</p>
  </div>

  <div>
    <h2
      class="text-xs font-semibold text-zinc-500 tracking-widest uppercase mb-3"
    >
      About
    </h2>
    <p class="text-sm leading-relaxed">{shortBio}</p>
  </div>

  {
    (mode === "all" || mode === "software") && (
      <div>
        <h2 class="text-xs font-semibold text-zinc-500 tracking-widest uppercase mb-3">
          Software Development
        </h2>
        <div class="flex flex-wrap gap-2">
          {softwareSkills.map((skill) => (
            <span class="px-3 py-1 text-xs border border-zinc-800 rounded-full bg-zinc-900/50">
              {skill}
            </span>
          ))}
        </div>
      </div>
    )
  }

  {
    (mode === "all" || mode === "marketing") && (
      <div>
        <h2 class="text-xs font-semibold text-zinc-500 tracking-widest uppercase mb-3">
          Marketing
        </h2>
        <div class="flex flex-wrap gap-2">
          {marketingSkills.map((skill) => (
            <span class="px-3 py-1 text-xs border border-zinc-800 rounded-full bg-zinc-900/50">
              {skill}
            </span>
          ))}
        </div>
      </div>
    )
  }

  <div>
    <h2
      class="text-xs font-semibold text-zinc-500 tracking-widest uppercase mb-3"
    >
      Contact
    </h2>
    <ul class="space-y-2 text-sm text-zinc-400">
      <li>
        <a
          href={`mailto:${contact.email}`}
          class="hover:text-white transition-colors">✉️ {contact.email}</a>
      </li>
      <li>
        <a
          href={`https://${contact.linkedin}`}
          target="_blank"
          class="hover:text-white transition-colors">🔗 LinkedIn</a>
      </li>
    </ul>
  </div>
</aside>
