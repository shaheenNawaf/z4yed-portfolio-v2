---
interface Props {
  ctaText: string;
  contactEmail: string;
  linkedinUrl: string;
  profileImage: string;
  name: string;
  statusText?: string;
  resumeUrl?: string;
}

const {
  ctaText,
  contactEmail,
  linkedinUrl,
  profileImage,
  name,
  statusText = "Available for roles & projects",
  resumeUrl = "/resume.pdf",
} = Astro.props;
---

<div
  id="sticky-cta"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[100] w-[94%] max-w-xl translate-y-40 transition-transform duration-700 ease-in-out pointer-events-none"
>
  {
    /* Nested inside bobbing wrapper to prevent transition collisions with slide-in logic */
  }
  <div class="animate-bob pointer-events-auto">
    <div
      class="sticky-bar-panel bg-zinc-900/90 backdrop-blur-md border border-zinc-800 p-2 rounded-2xl flex items-center justify-between"
    >
      <div class="flex items-center gap-2.5 pl-1 min-w-0">
        <div class="relative shrink-0 flex items-center">
          <img
            src={profileImage}
            class="w-10 h-10 rounded-xl object-cover border border-zinc-800"
            alt={name}
          />
          {/* Pulsing hiring indicator dot targeting headhunter attention */}
          <span
            class="absolute -top-0.5 -right-0.5 w-3 h-3 bg-green-500 rounded-full border-2 border-zinc-900 animate-pulse"
          ></span>
        </div>
        <div class="flex flex-col min-w-0">
          <p
            class="text-white text-xs md:text-sm font-semibold tracking-tight leading-none truncate"
          >
            {name}
          </p>
          {/* Hidden on mobile to free up space, shown on larger screens */}
          <p
            class="hidden sm:block text-zinc-500 text-[9px] uppercase tracking-wider mt-1.5 truncate"
          >
            {statusText}
          </p>
        </div>
      </div>

      <div class="flex items-center gap-1.5 md:gap-2 shrink-0">
        {/* Direct PDF Resume instant download button */}
        <a
          href={resumeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="p-2 md:p-2.5 rounded-lg md:rounded-xl border border-zinc-800 text-zinc-400 hover:text-green-400 hover:border-zinc-700 transition-all bg-zinc-950/50 shrink-0"
          title="View Resume"
        >
          <svg
            class="w-4 h-4 md:w-5 md:h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
            ></path>
          </svg>
        </a>

        {/* LinkedIn portal */}
        <a
          href={`https://${linkedinUrl}`}
          target="_blank"
          class="p-2.5 rounded-xl border border-zinc-800 text-zinc-400 hover:text-blue-400 hover:border-zinc-700 transition-all bg-zinc-950/50 shrink-0"
          title="LinkedIn Profile"
        >
          <svg
            class="w-4 h-4 md:w-5 md:h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            ><path
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
            ></path></svg
          >
        </a>

        {/* Primary Call-to-Action email link */}
        <a
          href={`mailto:${contactEmail}`}
          class="cta-btn bg-white text-black px-4 py-2.5 rounded-xl text-xs font-bold uppercase tracking-wider hover:bg-zinc-200 transition-all active:scale-95 shrink-0"
        >
          {ctaText}
        </a>
      </div>
    </div>
  </div>
</div>
