---
import { hub } from "../data/resume";

interface Props {
  ctaText?: string;
  linkedinUrl: string;
  profileImage: string;
  name: string;
  statusText?: string;
  resumeUrl?: string;
  ctaHref?: string;
}

const {
  ctaText = hub.ctaPrimary,
  linkedinUrl,
  profileImage,
  name,
  statusText = "Remote · SEA · Open to roles",
  resumeUrl = "/resume.pdf",
  ctaHref = "#book-call",
} = Astro.props;
---

<div
  id="sticky-cta"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 z-[100] w-[94%] max-w-xl translate-y-40 transition-transform duration-700 ease-in-out pointer-events-none"
>
  <div class="pointer-events-auto">
    <div
      class="surface flex items-center justify-between p-2 rounded-2xl"
    >
      <div class="flex items-center gap-2.5 pl-1 min-w-0">
        <div class="relative shrink-0 flex items-center">
          <img
            src={profileImage}
            class="w-10 h-10 rounded-xl object-cover border hairline"
            alt={name}
          />
          <span
            class="absolute -top-0.5 -right-0.5 w-3 h-3 bg-green-500 rounded-full border-2 border-[color:var(--bg)] animate-pulse"
          ></span>
        </div>
        <div class="flex flex-col min-w-0">
          <p
            class="text-[color:var(--text)] text-xs md:text-sm font-semibold tracking-tight leading-none truncate"
          >
            {name}
          </p>
          <p
            class="hidden sm:block faint text-[9px] uppercase tracking-wider mt-1.5 truncate"
          >
            {statusText}
          </p>
        </div>
      </div>

      <div class="flex items-center gap-1.5 md:gap-2 shrink-0">
        <a
          href={resumeUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="surface p-2 md:p-2.5 rounded-lg md:rounded-xl text-[color:var(--text-muted)] hover:text-[color:var(--accent)] hover:border-[color:var(--border-strong)] transition-all shrink-0"
          title="View Resume"
        >
          <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
        </a>

        <a
          href={`https://${linkedinUrl}`}
          target="_blank"
          rel="noopener noreferrer"
          class="surface p-2.5 rounded-xl text-[color:var(--text-muted)] hover:text-[color:var(--accent)] hover:border-[color:var(--border-strong)] transition-all shrink-0"
          title="LinkedIn Profile"
        >
          <svg class="w-4 h-4 md:w-5 md:h-5" fill="currentColor" viewBox="0 0 24 24"
            ><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path></svg
          >
        </a>

        <a
          href={ctaHref}
          class="track-btn px-4 py-2.5 rounded-xl text-xs font-bold uppercase tracking-wider transition-all active:scale-95 shrink-0"
        >
          {ctaText}
        </a>
      </div>
    </div>
  </div>
</div>
