---
import { experiences, experienceTech } from "../data/resume";
import CategorySwitcher from "./category_switcher.astro";
---

<section id="experience" class="relative py-16 md:py-32">
  <div class="max-w-6xl mx-auto px-5 md:px-8">
    <div class="mb-10 md:mb-16">
      <h2
        class="text-3xl md:text-4xl font-bold text-[color:var(--text)] tracking-tight"
      >
        Career
      </h2>
      <p class="mt-3 text-base md:text-lg muted max-w-2xl">
        Professional progression across engineering and growth.
      </p>
    </div>

    <div class="mb-8">
      <CategorySwitcher
        targetSelector="[data-experience-list]"
        itemSelector="[data-experience-card]"
        storageKey="experience-category"
        categories={[
          { id: "all", label: "All" },
          { id: "software", label: "Software" },
          { id: "marketing", label: "Growth Marketing" },
        ]}
      />
    </div>

    <ol class="relative ml-2 md:ml-3 border-l hairline" data-experience-list>
      {
        experiences.map((exp, index) => {
          const tech = experienceTech[exp.id] ?? [];
          const isFirst = index === 0;
          return (
            <li
              class:list={[
                "relative pl-6 md:pl-10 pb-12 last:pb-0",
                index < experiences.length - 1 && "border-b border-[color:color-mix(in_srgb,var(--border)_18%,transparent)]",
              ]}
              data-experience-card
              data-category={exp.category}
              style={`--card-accent: ${exp.category === "marketing" ? "var(--mkt)" : "var(--sw)"}`}
            >
              <span
                class="absolute -left-[5px] top-2 w-2.5 h-2.5 rounded-full border-2"
                style={`background-color: var(--bg); border-color: var(--card-accent)`}
                aria-hidden="true"
              />
              <div class="panel radius-card px-6 md:px-8 py-8">
                {/* Desktop header — unchanged */}
                <div class="hidden md:block">
                  <div class="flex flex-wrap items-baseline justify-between gap-2 mb-4">
                    <div>
                      <h3 class="text-[18px] font-bold text-[color:var(--text)] tracking-tight">
                        {exp.title}
                      </h3>
                      <p class="text-[14px] text-[color:var(--text-muted)] mt-0.5">
                        {exp.company}
                      </p>
                    </div>
                    <span class="text-[14px] text-[color:var(--text-muted)]">
                      {exp.date}
                    </span>
                  </div>
                </div>

                {/* Mobile accordion header */}
                <div
                  class="accordion-trigger md:hidden w-full text-left pb-3"
                  role="button"
                  tabindex="0"
                  aria-expanded={isFirst ? "true" : "false"}
                  aria-controls={`exp-content-${index}`}
                  id={`exp-trigger-${index}`}
                >
                  <div class="flex flex-wrap items-baseline justify-between gap-2 mb-2">
                    <span class="text-base font-semibold text-[color:var(--text)] tracking-tight">
                      {exp.company}
                    </span>
                    <span class="font-mono text-[10px] uppercase tracking-widest muted">
                      {exp.date}
                    </span>
                  </div>
                  <div class="flex items-center justify-between gap-3">
                    <span class="text-[color:var(--card-accent)] text-[12px] font-bold uppercase tracking-widest">
                      {exp.title}
                    </span>
                    <span class="accordion-chevron" aria-hidden="true">
                      <svg
                        class="w-4 h-4"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M6 9l6 6 6-6" />
                      </svg>
                    </span>
                  </div>
                </div>

                <div
                  class={`accordion-content ${isFirst ? "is-open" : ""}`}
                  id={`exp-content-${index}`}
                  role="region"
                  aria-labelledby={`exp-trigger-${index}`}
                >
                  <p class="muted text-[15px] leading-[1.7] mb-4 max-w-[680px]">
                    {exp.description}
                  </p>
                  {exp.details.length > 0 && (
                    <ul class="space-y-2 mb-4">
                      {exp.details.slice(0, 3).map((d) => (
                        <li class="flex items-start gap-2 text-[14px] muted leading-[1.7]">
                          <span
                            class="mt-1.5 w-1 h-1 rounded-full shrink-0"
                            style={`background-color: var(--card-accent)`}
                          />
                          {d}
                        </li>
                      ))}
                    </ul>
                  )}
                  {tech.length > 0 && (
                    <div class="flex flex-wrap gap-1.5 pt-4 border-t hairline">
                      {tech.map((t) => (
                        <span class="px-2 py-0.5 panel radius-btn text-[10px] font-mono muted">
                          {t}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </li>
          );
        })
      }
    </ol>
  </div>
</section>

<script is:inline>
  (function () {
    const list = document.querySelector('[data-experience-list]');
    if (!list) return;
    const triggers = Array.from(list.querySelectorAll('.accordion-trigger'));
    if (triggers.length === 0) return;

    const update = (trigger, isOpen) => {
      trigger.setAttribute('aria-expanded', String(isOpen));
      const content = document.getElementById(
        trigger.getAttribute('aria-controls')
      );
      if (content) content.classList.toggle('is-open', isOpen);
    };

    triggers.forEach((trigger, index) => {
      if (index === 0) update(trigger, true);

      const toggle = () => {
        if (window.innerWidth >= 768) return;
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        triggers.forEach((t) => update(t, false));
        if (!isOpen) update(trigger, true);
      };

      trigger.addEventListener('click', toggle);
      trigger.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          toggle();
        }
      });
    });
  })();
</script>

<style>
  .accordion-trigger {
    cursor: pointer;
  }

  .accordion-chevron {
    color: var(--text-muted);
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .accordion-trigger[aria-expanded="true"] .accordion-chevron {
    transform: rotate(180deg);
  }

  .accordion-content {
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition: max-height 0.3s ease, opacity 0.3s ease;
  }

  .accordion-content.is-open {
    max-height: 1000px;
    opacity: 1;
  }

  @media (min-width: 768px) {
    .accordion-content,
    .accordion-content.is-open {
      max-height: none;
      opacity: 1;
      overflow: visible;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .accordion-content {
      transition: none;
    }
    .accordion-chevron {
      transition: none;
    }
  }
</style>
