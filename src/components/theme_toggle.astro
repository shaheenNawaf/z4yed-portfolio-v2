---
const positionClass =
  "relative cursor-pointer p-2 md:p-3.5 rounded-lg md:rounded-xl surface text-[color:var(--text-muted)] hover:text-[color:var(--text)] hover:border-[color:var(--border-strong)] transition-all hover:scale-110";
---

<button
  id="theme-toggle"
  class={`${positionClass} border hairline`}
  aria-label="Toggle Theme"
>
  <svg
    id="sun-icon"
    class="w-3.5 h-3.5 md:w-6 md:h-6 block"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.5"
      d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707.707M12 8a4 4 0 100 8 4 4 0 000-8z"
    ></path>
  </svg>

  <svg
    id="moon-icon"
    class="w-3.5 h-3.5 md:w-6 md:h-6 hidden"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="1.5"
      d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
    ></path>
  </svg>
</button>
