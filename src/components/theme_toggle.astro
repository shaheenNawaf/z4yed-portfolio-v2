---
interface Props {
  variant?: "fixed" | "inline";
}
const { variant = "fixed" } = Astro.props;
const positionClass = variant === "inline"
  ? "relative p-2.5 md:p-3 rounded-xl md:rounded-xl"
  : "fixed top-4 right-4 md:top-6 md:right-6 z-[100] p-2 md:p-3 rounded-xl md:rounded-2xl shadow-2xl";
---

<button 
  id="theme-toggle" 
  class={`${positionClass} border border-zinc-800 bg-zinc-900/50 backdrop-blur-md text-zinc-400 hover:text-white transition-all pointer-events-auto`}
  aria-label="Toggle Theme"
>
  <svg id="sun-icon" class="w-4 h-4 md:w-5 md:h-5 block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707.707M12 8a4 4 0 100 8 4 4 0 000-8z"></path>
  </svg>
  
  <svg id="moon-icon" class="w-4 h-4 md:w-5 md:h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
  </svg>
</button>

<style>
  :global(html.light) #sun-icon { display: none; }
  :global(html.light) #moon-icon { display: block; }
  :global(html.light) #theme-toggle {
    background-color: rgba(255, 255, 255, 0.85);
    border-color: #d9d6cf;
    color: #1c1917;
  }
</style>