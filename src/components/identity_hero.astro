---
interface Props {
  name: string;
  headline: string;
  image: string;
  summary: string;
  skills: readonly string[];
  contact: { email: string; linkedin: string };
  mode: "software" | "marketing";
  impactBadge?: string;
  resumeUrl?: string;
}

const {
  name,
  headline,
  image,
  summary,
  skills,
  contact,
  mode,
  impactBadge,
  resumeUrl,
} = Astro.props;
---

<section
  class="zone-surface relative overflow-hidden p-6 md:p-10 shadow-sm"
>
  <div class="absolute inset-0 zone-motif opacity-60 pointer-events-none"></div>

  <div class="relative z-10 flex flex-col md:flex-row gap-6 md:gap-12">
    <div class="flex flex-col gap-5 shrink-0 w-full md:w-auto">
      <div
        class="flex flex-row md:flex-col items-center md:items-start gap-4 md:gap-5"
      >
        <img
          src={image}
          alt={name}
          class="w-20 h-20 md:w-32 md:h-32 rounded-2xl object-cover border hairline shadow-sm shrink-0"
        />

        <div class="flex flex-col md:hidden text-left min-w-0 flex-1">
          <div class="flex flex-col gap-1.5 mb-1">
            <h1
              class="font-grotesk text-xl font-extrabold uppercase leading-tight truncate text-[color:var(--text)]"
            >
              {name}
            </h1>
            {
              impactBadge && (
                <span
                  class="inline-block px-2 py-0.5 rounded-full border text-[9px] font-bold uppercase tracking-widest w-fit track-accent-bg"
                >
                  {impactBadge}
                </span>
              )
            }
          </div>
          <p class="track-accent text-xs font-semibold">{headline}</p>
        </div>
      </div>

      <div class="hidden md:flex gap-3">
        <a
          href={`mailto:${contact.email}`}
          class="surface p-2 rounded-xl text-[color:var(--text-muted)] hover:text-[color:var(--accent)] hover:border-[color:var(--border-strong)] transition-all"
          title="Email"
        >
          <svg class="w-5 h-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
          </svg>
        </a>
        <a
          href={`https://${contact.linkedin}`}
          target="_blank"
          class="surface p-2 rounded-xl text-[color:var(--text-muted)] hover:text-[color:var(--accent)] hover:border-[color:var(--border-strong)] transition-all"
          title="LinkedIn"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path>
          </svg>
        </a>
        {
          resumeUrl && (
            <a
              href={resumeUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="surface p-2 rounded-xl text-[color:var(--text-muted)] hover:text-[color:var(--accent)] hover:border-[color:var(--border-strong)] transition-all"
              title="View Resume PDF"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
            </a>
          )
        }
      </div>

      <div class="flex md:hidden gap-3 w-full">
        <a
          href={`mailto:${contact.email}`}
          class="surface flex-1 flex items-center justify-center p-3.5 rounded-xl text-[color:var(--text-muted)] hover:text-[color:var(--accent)] transition-all"
          title="Email"
        >
          <svg class="w-5 h-5 shrink-0" viewBox="0 0 20 20" fill="currentColor">
            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"></path>
            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"></path>
          </svg>
          <span class="hidden sm:inline-block ml-2 text-xs font-bold uppercase tracking-wider">Email</span>
        </a>
        <a
          href={`https://${contact.linkedin}`}
          target="_blank"
          class="surface flex-1 flex items-center justify-center p-3.5 rounded-xl text-[color:var(--text-muted)] hover:text-[color:var(--accent)] transition-all"
          title="LinkedIn"
        >
          <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path>
          </svg>
          <span class="hidden sm:inline-block ml-2 text-xs font-bold uppercase tracking-wider">LinkedIn</span>
        </a>
        {
          resumeUrl && (
            <a
              href={resumeUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="surface flex-1 flex items-center justify-center p-3.5 rounded-xl text-[color:var(--text-muted)] hover:text-[color:var(--accent)] transition-all"
              title="View Resume PDF"
            >
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
              </svg>
              <span class="hidden sm:inline-block ml-2 text-xs font-bold uppercase tracking-wider">Resume</span>
            </a>
          )
        }
      </div>
    </div>

    <div class="flex-1 text-left">
      <div class="hidden md:block mb-6">
        <div class="flex items-center gap-3 mb-1">
          <h1
            class="font-grotesk text-3xl md:text-4xl font-extrabold uppercase tracking-tight text-[color:var(--text)]"
          >
            {name}
          </h1>
          {
            impactBadge && (
              <span
                class="inline-block px-3 py-1 rounded-full border text-[10px] font-bold uppercase tracking-widest w-fit track-accent-bg"
              >
                {impactBadge}
              </span>
            )
          }
        </div>
        <p class="track-accent text-base md:text-lg font-medium">{headline}</p>
      </div>

      <p class="muted text-sm md:text-base leading-relaxed mb-6">{summary}</p>

      <div class="flex flex-wrap items-center gap-3 mb-8">
        <a
          href="#book-call"
          class="track-btn inline-flex items-center gap-2 px-5 py-3 rounded-xl text-[11px] font-bold uppercase tracking-wider transition-all active:scale-[0.98]"
        >
          Book intro call
        </a>
        <a
          href={`https://${contact.linkedin}`}
          target="_blank"
          rel="noopener noreferrer"
          class="surface inline-flex items-center px-4 py-3 rounded-xl text-[11px] font-bold uppercase tracking-wider text-[color:var(--text-muted)] hover:text-[color:var(--accent)] hover:border-[color:var(--border-strong)] transition-all"
        >
          LinkedIn
        </a>
        {
          resumeUrl && (
            <a
              href={resumeUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="surface inline-flex items-center px-4 py-3 rounded-xl text-[11px] font-bold uppercase tracking-wider text-[color:var(--text-muted)] hover:text-[color:var(--accent)] hover:border-[color:var(--border-strong)] transition-all"
            >
              Resume
            </a>
          )
        }
      </div>

      <div class="border-t hairline pt-5">
        <h2 class="text-[10px] font-bold muted uppercase tracking-[0.2em] mb-3">
          Expertise
        </h2>
        <div class="flex flex-wrap justify-start gap-2">
          {
            skills.map((skill) => (
              <span class="px-3 py-1 surface-2 border hairline rounded-lg text-[11px] muted font-medium">
                {skill}
              </span>
            ))
          }
        </div>
      </div>

      <div class="mt-6 border-t hairline pt-5">
        <h2 class="text-[10px] font-bold muted uppercase tracking-[0.2em] mb-3">
          Tools & Stack
        </h2>
        <div class="flex flex-wrap justify-start gap-x-5 gap-y-2">
          {
            mode === "software" ? (
              <>
                <span class="text-[11px] muted flex items-center gap-2"><span class="w-1 h-1 rounded-full" style="background-color: var(--accent)"></span> Cursor & VS Code</span>
                <span class="text-[11px] muted flex items-center gap-2"><span class="w-1 h-1 rounded-full" style="background-color: var(--accent)"></span> Android Studio</span>
                <span class="text-[11px] muted flex items-center gap-2"><span class="w-1 h-1 rounded-full" style="background-color: var(--accent)"></span> Postman</span>
                <span class="text-[11px] muted flex items-center gap-2"><span class="w-1 h-1 rounded-full" style="background-color: var(--accent)"></span> Firebase & Supabase</span>
                <span class="text-[11px] muted flex items-center gap-2"><span class="w-1 h-1 rounded-full" style="background-color: var(--accent)"></span> Bubble.io</span>
                <span class="text-[11px] muted flex items-center gap-2"><span class="w-1 h-1 rounded-full" style="background-color: var(--accent)"></span> Docker</span>
              </>
            ) : (
              <>
                <span class="text-[11px] muted flex items-center gap-2"><span class="w-1 h-1 rounded-full" style="background-color: var(--accent)"></span> Meta Business Suite</span>
                <span class="text-[11px] muted flex items-center gap-2"><span class="w-1 h-1 rounded-full" style="background-color: var(--accent)"></span> Telegram & Viber</span>
                <span class="text-[11px] muted flex items-center gap-2"><span class="w-1 h-1 rounded-full" style="background-color: var(--accent)"></span> Figma & Canva</span>
                <span class="text-[11px] muted flex items-center gap-2"><span class="w-1 h-1 rounded-full" style="background-color: var(--accent)"></span> Notion & Airtable</span>
                <span class="text-[11px] muted flex items-center gap-2"><span class="w-1 h-1 rounded-full" style="background-color: var(--accent)"></span> HubSpot</span>
              </>
            )
          }
          <span class="text-[11px] muted flex items-center gap-2">
            <span class="w-1 h-1 rounded-full" style="background-color: var(--border-strong)"></span> Claude, ChatGPT & n8n
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
