---
interface Props {
  name: string;
  headline: string;
  image: string;
  summary: string;
  skills: readonly string[];
  contact: { email: string; linkedin: string };
  mode: "software" | "marketing";
  impactBadge?: string;
}

const { name, headline, image, summary, skills, contact, mode, impactBadge } =
  Astro.props;
const accentColor = mode === "software" ? "text-blue-500" : "text-orange-500";
const dotColor = mode === "software" ? "bg-blue-500" : "bg-orange-500";
---

<section
  class="bg-zinc-950/60 backdrop-blur-xl border border-white/10 rounded-[2rem] p-8 md:p-10 shadow-sm"
>
  <div class="flex flex-col md:flex-row gap-8 md:gap-12">
    <div class="flex flex-col items-center md:items-start gap-5 shrink-0">
      <img
        src={image}
        alt={name}
        class="w-28 h-28 md:w-32 md:h-32 rounded-2xl object-cover border border-zinc-800 shadow-sm"
      />

      <div class="flex gap-3">
        <a
          href={`mailto:${contact.email}`}
          class="p-2 rounded-xl border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-700 transition-all bg-zinc-950/20"
          title="Email"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path></svg
          >
        </a>
        <a
          href={`https://${contact.linkedin}`}
          target="_blank"
          class={`p-2 rounded-xl border border-zinc-800 text-zinc-400 hover:${accentColor} hover:border-zinc-700 transition-all bg-zinc-950/20`}
          title="LinkedIn"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
            ><path
              d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
            ></path></svg
          >
        </a>
      </div>
    </div>

    <div class="flex-1 text-center md:text-left">
      <div class="mb-6">
        <div class="flex flex-col md:flex-row md:items-center gap-3 mb-1">
          <h1
            class="text-3xl md:text-4xl font-semibold text-white tracking-tight"
          >
            {name}
          </h1>
          {
            impactBadge && (
              <span class="inline-block px-3 py-1 rounded-full bg-orange-500/10 border border-orange-500/20 text-orange-500 text-[10px] font-bold uppercase tracking-widest w-fit mx-auto md:mx-0">
                {impactBadge}
              </span>
            )
          }
        </div>
        <p class={`${accentColor} text-base md:text-lg font-medium`}>
          {headline}
        </p>
      </div>

      <p class="text-zinc-400 text-sm md:text-base leading-relaxed mb-8">
        {summary}
      </p>

      <div class="border-zinc-800/50">
        <h2
          class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-3"
        >
          Expertise
        </h2>
        <div class="flex flex-wrap justify-center md:justify-start gap-2">
          {
            skills.map((skill) => (
              <span class="px-3 py-1 bg-zinc-950/30 border border-zinc-800 rounded-lg text-[11px] text-zinc-400 font-medium">
                {skill}
              </span>
            ))
          }
        </div>
      </div>

      <div class="mt-6 border-zinc-800/50">
        <h2
          class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] mb-3"
        >
          Tools & AI Stack
        </h2>
        <div
          class="flex flex-wrap justify-center md:justify-start gap-x-5 gap-y-2"
        >
          {
            mode === "software" ? (
              <>
                <span class="text-[11px] text-zinc-500 flex items-center gap-2">
                  <span class={`w-1 h-1 ${dotColor} rounded-full`} /> Cursor &
                  VS Code
                </span>
                <span class="text-[11px] text-zinc-500 flex items-center gap-2">
                  <span class={`w-1 h-1 ${dotColor} rounded-full`} /> Postman
                </span>
                <span class="text-[11px] text-zinc-500 flex items-center gap-2">
                  <span class={`w-1 h-1 ${dotColor} rounded-full`} /> Firebase &
                  Supabase
                </span>
              </>
            ) : (
              <>
                <span class="text-[11px] text-zinc-500 flex items-center gap-2">
                  <span class={`w-1 h-1 ${dotColor} rounded-full`} /> Meta
                  Business Suite
                </span>
                <span class="text-[11px] text-zinc-500 flex items-center gap-2">
                  <span class={`w-1 h-1 ${dotColor} rounded-full`} /> Figma &
                  Canva
                </span>
                <span class="text-[11px] text-zinc-500 flex items-center gap-2">
                  <span class={`w-1 h-1 ${dotColor} rounded-full`} /> Notion &
                  Airtable
                </span>
              </>
            )
          }
          <span class="text-[11px] text-zinc-500 flex items-center gap-2">
            <span class="w-1 h-1 bg-zinc-600 rounded-full"></span> Claude, ChatGPT
            & Grok
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
