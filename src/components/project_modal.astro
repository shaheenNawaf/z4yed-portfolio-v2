---
import Watermark from "./watermark.astro";
import type { Category } from "../data/resume";

interface Props {
  id: string;
  title: string;
  date: string;
  role: string;
  color: string;
  category: Category;
  description: string;
  results?: string;
  deliverables?: string[];
  gallery?: string[];
  tags?: readonly string[];
  media?: { type: "video" | "image"; url: string; thumbnail?: string };
  liveUrl?: string;
  repoUrl?: string;
  problem?: string;
  solution?: string;
  impact?: string;
  caseStudyHref?: string;
}

const {
  id,
  title,
  date,
  role,
  color,
  category,
  description,
  results,
  deliverables = [],
  gallery = [],
  tags = [],
  media,
  liveUrl,
  repoUrl,
  problem,
  solution,
  impact,
  caseStudyHref,
} = Astro.props;

const cardImage =
  media?.type === "video" && media.thumbnail ? media.thumbnail : media?.url;
const fallBackImage = `https://picsum.photos/seed/${id}/800/600`;
const metric = results ?? impact;

const accentVar =
  category === "marketing" ? "var(--mkt)" : category === "software" ? "var(--sw)" : "var(--accent)";

const shadowClass =
  category === "marketing" ? "modal-shadow-marketing" : category === "software" ? "modal-shadow-software" : "modal-shadow-systems";
---

<dialog
  id={`modal-${id}`}
  class={`project-modal fixed inset-0 m-auto backdrop-blur-xl radius-card max-w-3xl w-[95%] focus:outline-none overflow-hidden ${shadowClass}`}
  data-project-modal={id}
>
  <div class="flex flex-col relative max-h-[90dvh] overflow-y-auto">
    <button
      class="close-modal absolute top-4 right-4 z-50 w-10 h-10 rounded-full flex items-center justify-center transition-all border"
      aria-label="Close case study"
    >
      ✕
    </button>

    {/* Hero Section */}
    <div
      class="w-full relative flex items-center justify-center shrink-0 border-b hairline overflow-hidden"
      style={`background-color: ${color}18; aspect-ratio: ${media?.type === 'video' ? '16/9' : '16/9'}`}
    >
      {
        media?.type === "video" ? (
          <video class="w-full h-full object-cover" controls playsinline preload="metadata">
            <source src={media.url} type="video/mp4" />
          </video>
        ) : media?.url ? (
          <div class="relative w-full h-full overflow-hidden protected-image select-none">
            <img src={media.url} alt={title} class="w-full h-full object-cover" />
            <Watermark />
          </div>
        ) : (
          <div class="absolute inset-0">
            <img
              src={fallBackImage}
              alt={title}
              class="w-full h-full object-cover opacity-70"
            />
            <div
              class="absolute inset-0 opacity-20"
              style="background-image: radial-gradient(circle, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 24px 24px;"
            />
          </div>
        )
      }
    </div>

    <div class="p-8 md:p-12">
      {/* Hero Info */}
      <div class="flex flex-col md:flex-row justify-between items-start gap-6 mb-10">
        <div class="flex-1">
          <div class="flex items-center gap-3 mb-3">
            <span
              class="px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-widest"
              style={`background-color: ${accentVar}20; color: ${accentVar}`}
            >
              {category}
            </span>
            <span class="text-[11px] font-mono muted">{date}</span>
          </div>
          <h2
            class="text-3xl md:text-4xl font-semibold text-[color:var(--text)] tracking-tighter mb-2 leading-tight"
          >
            {title}
          </h2>
          <p
            class="text-[color:var(--card-accent)] font-bold uppercase tracking-[0.2em] text-xs"
            style={`--card-accent: ${accentVar}`}
          >
            {role}
          </p>
        </div>
        {
          metric && (
            <div
              class="p-4 rounded-2xl min-w-[140px] text-center border"
              style={`background-color: ${accentVar}10; border-color: ${accentVar}40`}
            >
              <span
                class="text-[10px] font-bold uppercase block mb-1 tracking-widest"
                style={`color: ${accentVar}99`}
              >
                Outcome
              </span>
              <span class="text-xl font-bold text-[color:var(--text)]">{metric}</span>
            </div>
          )
        }
      </div>

      {/* Overview Section */}
      <div class="mb-10">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] muted mb-4">
          Overview
        </h4>
        <p class="text-base leading-relaxed muted">{description}</p>
      </div>

      {/* Problem Section */}
      {
        problem && (
          <div class="mb-10">
            <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] muted mb-4">
              Problem
            </h4>
            <p class="text-base leading-relaxed muted">{problem}</p>
          </div>
        )
      }

      {/* Solution Section */}
      {
        solution && (
          <div class="mb-10">
            <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] muted mb-4">
              Solution
            </h4>
            <p class="text-base leading-relaxed muted">{solution}</p>
          </div>
        )
      }

      {/* Execution Section */}
      <div class="mb-10">
        <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] muted mb-4">
          Execution
        </h4>
        <p class="text-base leading-relaxed muted">{description}</p>
      </div>

      {/* Impact Section */}
      {
        impact && (
          <div class="mb-10 p-6 rounded-2xl border" style={`background-color: ${accentVar}08; border-color: ${accentVar}30`}>
            <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] mb-4" style={`color: ${accentVar}`}>
              Business Impact
            </h4>
            <p class="text-lg font-semibold text-[color:var(--text)]">{impact}</p>
          </div>
        )
      }

      {/* Technology Section */}
      {
        tags.length > 0 && (
          <div class="mb-10">
            <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] muted mb-4">
              Technology
            </h4>
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="px-3 py-1.5 panel radius-btn text-xs font-mono muted">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        )
      }

      {/* Gallery Section */}
      {
        gallery.length > 0 && (
          <div class="mb-10">
            <h4 class="text-[10px] font-bold uppercase tracking-[0.2em] muted mb-6">
              Gallery
            </h4>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
              {gallery.map((img) => (
                <div class="aspect-square rounded-xl overflow-hidden border hairline bg-[color:var(--card-bg-2)] group/img protected-image relative select-none">
                  <img
                    src={img}
                    alt="Project gallery image"
                    class="w-full h-full object-cover transition-transform duration-700 group-hover/img:scale-110"
                    loading="lazy"
                  />
                  <Watermark />
                </div>
              ))}
            </div>
          </div>
        )
      }

      {/* Action Links */}
      {
        (liveUrl || repoUrl) && (
          <div class="border-t hairline pt-8 flex flex-wrap gap-3">
            {liveUrl && liveUrl.length > 0 && (
              <a
                href={liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl text-sm font-semibold transition-all active:scale-95 text-white"
                style={`background-color: ${accentVar}`}
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
                Visit Live Site
              </a>
            )}
            {repoUrl && repoUrl.length > 0 && (
              <a
                href={repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-6 py-2.5 bg-[color:var(--card-bg-2)] hover:border-[color:var(--border-strong)] text-[color:var(--text)] rounded-xl text-sm font-semibold transition-colors active:scale-95 border hairline"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                </svg>
                View Code
              </a>
            )}
          </div>
        )
      }
    </div>
  </div>
</dialog>

<style>
  .project-modal {
    background-color: var(--card-bg-2);
    border: 1px solid var(--border);
    color: var(--text);
    border-radius: var(--radius-card);
  }

  .modal-shadow-software { box-shadow: 0 0 50px -12px rgba(59, 130, 246, 0.3); }
  .modal-shadow-marketing { box-shadow: 0 0 50px -12px rgba(249, 115, 22, 0.3); }
  .modal-shadow-systems { box-shadow: 0 0 50px -12px rgba(168, 85, 247, 0.3); }

  .close-modal {
    background-color: color-mix(in srgb, var(--text) 8%, transparent);
    border: 1px solid var(--border);
    color: var(--text);
  }
  .close-modal:hover { background-color: color-mix(in srgb, var(--text) 16%, transparent); }
</style>
