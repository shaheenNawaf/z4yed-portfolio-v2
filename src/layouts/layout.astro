---
import "../styles/global.css";
import ThemeToggle from "../components/theme_toggle.astro";

interface Props {
  title: string;
  description?: string;
  hideToggle?: boolean;
}

const {
  title,
  description = "Full-stack Software Engineer & Growth Marketer based in Davao, Philippines.",
  hideToggle = false,
} = Astro.props;

const siteUrl = "https://shaheen.works";
const ogImage = `${siteUrl}/thumbnail.png`;
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
---

<html lang="en" class="antialiased selection:bg-blue-500/30">
  <head>
    <script src="../scripts/theme-init.ts"></script>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {/* Standardized multi-platform favicon declarations with cache-busters */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="alternate icon" type="image/x-icon" href="/favicon.ico?v=2" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon.png?v=2"
    />

    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Shaheen Aladwani" />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={siteUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
  </head>

  <body class="min-h-screen font-sans relative transition-colors duration-300">
    {!hideToggle && <ThemeToggle />}

    <slot />

    {
      /* Loads general site-wide interactives including modals and CTA tracking */
    }
    <script src="../scripts/main.ts"></script>
  </body>
</html>
