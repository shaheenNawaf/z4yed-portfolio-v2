---
import BaseLayout from '../layouts/layout.astro';
import IdentityHero from '../components/identity_hero.astro';
import MarketingCard from '../components/marketing_card.astro';
import ExperienceCard from '../components/experience_card.astro';
import StickyBar from '../components/sticky_bar.astro';
import { name, marketingSummary, projects, experiences, marketingSkills, contact, creativeGallery } from '../data/resume';

const marketingProjects = projects.filter(p => p.category === 'marketing');
const marketingExp = experiences.filter(e => e.category === 'marketing');
---

<BaseLayout title="Shaheen | Creator Partnerships">
  <div id="hero-trigger" class="absolute top-0 h-20 w-full pointer-events-none"></div>

  <main class="max-w-4xl mx-auto w-full flex flex-col gap-16 py-12 px-6">
    <nav>
      <a href="/" class="text-[10px] font-bold tracking-[0.2em] text-zinc-500 hover:text-white transition-colors uppercase">← Back to Portal</a>
    </nav>

    <IdentityHero 
      name={name}
      headline="Creator Partnerships Specialist"
      image={contact.profileImage}
      summary={marketingSummary}
      skills={marketingSkills}
      contact={contact}
      mode="marketing"
      impactBadge="$355K+ Managed Volume in 4 m"
    />

    <section>
      <div class="flex items-center gap-4 mb-8">
        <h2 class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em]">Campaign Case Studies</h2>
        <div class="h-px flex-1 bg-zinc-800/50"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {marketingProjects.map(project => <MarketingCard {...project} />)}
      </div>
    </section>

    <section>
      <div class="flex items-center gap-4 mb-8">
        <h2 class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em]">Professional History</h2>
        <div class="h-px flex-1 bg-zinc-800/50"></div>
      </div>
      <div class="flex flex-col gap-4">
        {marketingExp.map(exp => <ExperienceCard {...exp} />)}
      </div>
    </section>

