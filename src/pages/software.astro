---
import BaseLayout from "../layouts/layout.astro";
import IdentityHero from "../components/identity_hero.astro";
import ProjectCard from "../components/project_card.astro";
import ProjectModal from "../components/project_modal.astro";
import ExperienceCard from "../components/experience_card.astro";
import StickyBar from "../components/sticky_bar.astro";
import ZoneNav from "../components/zone_nav.astro";
import BookCall from "../components/book_call.astro";

import {
  name,
  softwareSummary,
  projects,
  experiences,
  softwareSkills,
  contact,
  resumes,
  featuredProjectIds,
  softwareFit,
  hub,
  trustLogos,
} from "../data/resume";

const featured = featuredProjectIds.software
  .map((id) => projects.find((p) => p.id === id))
  .filter(Boolean);

const featuredIds = new Set<string>(featuredProjectIds.software);
const moreProjects = projects.filter(
  (p) => p.category === "software" && !featuredIds.has(p.id),
);
const softwareExp = experiences.filter((e) => e.category === "software");
---

<BaseLayout
  title="Shaheen | Software Engineering"
  description="Full-stack software engineer. Live SaaS, product shipping, remote SEA. Book an intro call."
  track="software"
  hideToggle={true}
>
  <div id="hero-trigger" class="absolute top-0 h-20 w-full pointer-events-none">
  </div>

  <main id="main" class="software-page max-w-4xl mx-auto w-full flex flex-col py-12 px-5 md:px-8">
    <ZoneNav mode="software" />

    <div class="flex flex-col gap-16 md:gap-20">
      <IdentityHero
        name={name}
        headline="Full-stack Software Engineer & Project Manager"
        image={contact.profileImage}
        summary={softwareSummary}
        skills={softwareSkills}
        contact={contact}
        mode="software"
        impactBadge="Dean's List · Ateneo de Davao"
        resumeUrl={resumes.software}
      />

      <section>
        <div
          class="flex flex-wrap items-center justify-between gap-4 radius-card border hairline bg-[color:var(--card-bg)] px-5 py-4"
        >
          <p class="text-xs muted max-w-sm leading-relaxed">
            Shipping owner for product and platforms. Open to full-time remote
            SEA roles; select freelance when the build is right.
          </p>
          <div class="flex items-center gap-6 opacity-60">
            {
              trustLogos.slice(0, 2).map((logo) => (
                <img src={logo.src} alt={logo.alt} class="h-6 w-auto object-contain" />
              ))
            }
          </div>
        </div>
      </section>

      <section>
        <div class="flex items-end justify-between gap-4 mb-8">
          <div>
            <h2
              class="zone-heading text-xl md:text-2xl font-bold tracking-tight"
            >
              Flagship builds
            </h2>
            <p class="mt-1 text-sm muted">
              Depth over volume. Live systems and real users.
            </p>
          </div>
          <a
            href="#book-call"
            class="hidden sm:inline-flex text-[10px] font-bold uppercase tracking-wider text-blue-400 hover:text-blue-300 transition-colors"
          >
            {hub.ctaPrimary}
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {
            featured.map((project) => project && <ProjectCard {...project} />)
          }
        </div>
      </section>

      <section class="zone-surface p-6 md:p-8">
        <h2
          class="zone-heading text-lg font-bold mb-4"
        >
          Good fit when you need
        </h2>
        <ul class="space-y-3">
          {
            softwareFit.map((item) => (
              <li class="flex items-start gap-3 text-sm muted">
                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-blue-500 shrink-0" />
                {item}
              </li>
            ))
          }
        </ul>
      </section>

      {
        moreProjects.length > 0 && (
          <section>
            <div class="flex items-center gap-4 mb-8">
              <h2 class="text-sm font-semibold muted">More projects</h2>
              <div class="h-px flex-1 hairline" />
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              {moreProjects.map((project) => (
                <ProjectCard {...project} />
              ))}
            </div>
          </section>
        )
      }

      <section>
        <div class="flex items-center gap-4 mb-8">
          <h2 class="text-sm font-semibold muted">Engineering history</h2>
          <div class="h-px flex-1 hairline" />
        </div>
        <div class="flex flex-col gap-4">
          {softwareExp.map((exp) => <ExperienceCard {...exp} />)}
        </div>
      </section>

      <section class="pb-24">
        <BookCall
          defaultInterest="software"
          title="Book a lab intro"
          subtitle="Talk product, stack, and how I ship. Full-time preferred."
        />
      </section>
    </div>
  </main>

  <StickyBar
    ctaText={hub.ctaPrimary}
    linkedinUrl={contact.linkedin}
    profileImage={contact.profileImage}
    name={name}
    statusText="Remote · SEA · Software roles"
    resumeUrl={resumes.software}
    ctaHref="#book-call"
    email={contact.email}
  />

  {/* Project Modals */}
  {[...featured, ...moreProjects].filter(Boolean).map((project) => project && (
    <ProjectModal {...project} />
  ))}
</BaseLayout>
