---
import BaseLayout from "../layouts/layout.astro";
import IdentityHero from "../components/identity_hero.astro";
import ProjectCard from "../components/project_card.astro";
import ExperienceCard from "../components/experience_card.astro";
import StickyBar from "../components/sticky_bar.astro";
import ThemeToggle from "../components/theme_toggle.astro";
import {
  name,
  softwareSummary,
  projects,
  experiences,
  softwareSkills,
  contact,
} from "../data/resume";

const softwareProjects = projects.filter((p) => p.category === "software");
const softwareExp = experiences.filter((e) => e.category === "software");
---

<BaseLayout title="Shaheen | Software Engineering" hideToggle={true}>
  <div id="hero-trigger" class="absolute top-0 h-20 w-full pointer-events-none">
  </div>

  <main class="software-page max-w-4xl mx-auto w-full flex flex-col py-12 px-6">
    {/* Navigation row with reduced bottom margin to pull Hero card closer */}
    <nav class="flex justify-between items-center w-full mb-6 md:mb-10">
      <a
        href="/"
        class="inline-flex items-center gap-2 py-2 md:py-0 px-4 md:px-6 h-auto md:h-[54px] rounded-xl border border-zinc-800 bg-zinc-900/40 backdrop-blur-sm text-zinc-400 hover:text-orange-400 hover:border-orange-500/30 hover:bg-zinc-800/60 transition-all text-[10px] md:text-[11px] font-bold uppercase tracking-[0.2em] group shrink-0"
      >
        <svg
          class="w-3.5 h-3.5 md:w-4 md:h-4 transition-transform group-hover:-translate-x-0.5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2.5"
            d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Portal
      </a>
      <ThemeToggle variant="inline" />
    </nav>

    {/* Layout content stack wrapper */}
    <div class="flex flex-col gap-16">
      <IdentityHero
        name={name}
        headline="Full-stack Software Engineer & Project Manager"
        image={contact.profileImage}
        summary={softwareSummary}
        skills={softwareSkills}
        contact={contact}
        mode="software"
        impactBadge="Dean's List · Ateneo de Davao"
        resumeUrl="https://docs.google.com/document/d/1fegmtrlKvyum3vJwKF9Vs8ELC9p7o4DuK4RyrKNJpno/export?format=pdf"
      />

      <section>
        {
          /* Adjusted tracking & added wrapping support to avoid mobile overflow */
        }
        <div class="flex items-center gap-4 mb-8">
          <span
            class="font-mono text-[10px] md:text-xs font-bold text-zinc-400 uppercase tracking-[0.2em] md:tracking-[0.35em] whitespace-normal break-words leading-relaxed"
          >
            // featured projects
          </span>
          <div class="h-px flex-1 bg-zinc-800/50"></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {softwareProjects.map((project) => <ProjectCard {...project} />)}
        </div>
      </section>

      <section class="pb-21">
        {
          /* Adjusted tracking & added wrapping support to avoid mobile overflow */
        }
        <div class="flex items-center gap-4 mb-8">
          <span
            class="font-mono text-[10px] md:text-xs font-bold text-zinc-400 uppercase tracking-[0.2em] md:tracking-[0.35em] whitespace-normal break-words leading-relaxed"
          >
            // engineering history & experience
          </span>
          <div class="h-px flex-1 bg-zinc-800/50"></div>
        </div>
        <div class="flex flex-col gap-4">
          {softwareExp.map((exp) => <ExperienceCard {...exp} />)}
        </div>
      </section>
    </div>
  </main>

  <StickyBar
    ctaText="Let's build"
    contactEmail={contact.email}
    linkedinUrl={contact.linkedin}
    profileImage={contact.profileImage}
    name={name}
    statusText="Available for Software Roles"
    resumeUrl="https://docs.google.com/document/d/1fegmtrlKvyum3vJwKF9Vs8ELC9p7o4DuK4RyrKNJpno/export?format=pdf
"
  />
</BaseLayout>
