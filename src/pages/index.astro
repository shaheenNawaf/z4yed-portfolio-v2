---
import BaseLayout from '../layouts/layout.astro';
import MarketingCard from '../components/marketing_card.astro';
import ProjectCard from '../components/project_card.astro';
import { name, shortBio, contact, projects, experiences } from '../data/resume';

// Category pill styles — fixed to brand colours, NOT per-company exp.color
const catStyle = {
  marketing: { color: 'rgb(251,146,60)',  border: 'rgba(249,115,22,0.35)', bg: 'rgba(249,115,22,0.1)'  },
  software:  { color: 'rgb(96, 165,250)', border: 'rgba(59, 130,246,0.35)', bg: 'rgba(59, 130,246,0.1)' },
};

const marketingProjects = projects.filter(p => p.category === 'marketing');
const softwareProjects  = projects.filter(p => p.category === 'software');

// Merge + sort all experiences, most recent first
const allExperiences = [...experiences].sort((a, b) => {
  const yearA = parseInt(a.date.match(/\d{4}/)?.[0] ?? '0');
  const yearB = parseInt(b.date.match(/\d{4}/)?.[0] ?? '0');
  return yearB - yearA;
});

const stats = [
  { value: "$355K+",  label: "Total Transaction Volume",  sub: "iGaming & D2C in just 4 months",         accent: "blue"   },
  { value: "22,000+", label: "Grew Communities to",   sub: "KYC-Gated members", accent: "orange" },
  { value: "37M+",    label: "Managed Macro-Influencers totalling",    sub: "Organic Followers",   accent: "blue"   },
  { value: "4:1",     label: "Validated ROAS",   sub: "Performance Marketing and Optimized Spend", accent: "orange" },
  { value: "30+",     label: "Produced Over",   sub: "Influencer content", accent: "blue" },
  { value: "20+",     label: "Created Over",   sub: "Campaigns (both Offline, Online and Online2Offline)", accent: "orange" },
];
---

<BaseLayout title={name}>

  <!-- Space Grotesk — wide geometric for hero headings -->
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@700;800&display=swap');
    .font-grotesk { font-family: 'Space Grotesk', sans-serif; }
  </style>

  <!-- ─── FLOATING HEADER ─────────────────────────────────────────────────── -->
  <header class="fixed top-6 md:top-8 left-1/2 -translate-x-1/2 z-50 w-[92%] max-w-2xl pointer-events-none">
    <div class="group/header bg-zinc-950/60 backdrop-blur-md border border-zinc-800 p-4 md:p-5 rounded-3xl shadow-2xl flex items-center gap-4 md:gap-6 pointer-events-auto transition-all hover:border-zinc-700 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-r from-orange-500/0 via-white/5 to-blue-500/0 opacity-0 group-hover/header:opacity-100 transition-opacity rounded-3xl"></div>
      <img src={contact.profileImage} alt={name} class="relative z-10 w-12 h-12 md:w-16 md:h-16 rounded-2xl object-cover border-2 border-zinc-800 shadow-inner" />
      <div class="relative z-10 text-left flex-1">
        <h1 class="text-lg md:text-xl font-semibold text-white tracking-tight leading-none">{name}</h1>
        <p class="text-zinc-400 text-[10px] md:text-xs mt-2 leading-relaxed max-w-sm line-clamp-1 md:line-clamp-none">{shortBio}</p>
      </div>
      <div class="relative z-10 flex items-center gap-2 md:gap-3 border-l border-zinc-800 pl-4 md:pl-6">
        <a href={`mailto:${contact.email}`} class="p-3 md:p-3.5 rounded-xl bg-zinc-900/50 border border-zinc-800 text-zinc-400 hover:text-white hover:border-zinc-600 transition-all hover:scale-110 shadow-lg" title="Email Me">
          <svg class="w-5 h-5 md:w-6 md:h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </a>
        <a href={`https://${contact.linkedin}`} target="_blank" rel="noopener noreferrer" class="md:flex p-3 md:p-3.5 rounded-xl bg-zinc-900/50 border border-zinc-800 text-zinc-400 hover:text-blue-400 hover:border-zinc-600 transition-all hover:scale-110 shadow-lg" title="LinkedIn">
          <svg class="w-5 h-5 md:w-6 md:h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
        </a>
      </div>
    </div>
  </header>


  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- SECTION 1 · HERO — Marketing LEFT · Software RIGHT                    -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <section class="relative h-screen flex flex-col md:flex-row overflow-hidden">

    <!-- Marketing panel — LEFT -->
    <a href="/marketing" class="group relative flex-1 flex items-center justify-center overflow-hidden border-b md:border-b-0 md:border-r border-zinc-800 transition-all duration-700 hover:flex-[1.4]">
      <div class="absolute inset-0 bg-orange-600/5 group-hover:bg-orange-600/10 transition-colors duration-700"></div>
      <div class="absolute inset-0 opacity-20 group-hover:opacity-40 transition-opacity duration-700"
           style="background-image: radial-gradient(circle, rgba(249,115,22,0.4) 1px, transparent 1px); background-size: 28px 28px;"></div>
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="w-96 h-64 rounded-full bg-orange-600/0 group-hover:bg-orange-600/8 blur-3xl transition-all duration-700"></div>
      </div>
      <div class="relative z-10 text-center p-8">
        <span class="text-orange-400 font-mono text-[12px] uppercase tracking-[0.3em] mb-4 block opacity-60 group-hover:opacity-100 transition-opacity">Growth & Scale</span>
        <h2 class="font-grotesk text-4xl md:text-6xl font-extrabold text-white mb-8 leading-none tracking-tight uppercase">
          CREATOR<br/><span class="text-orange-400">STRATEGIST</span>
        </h2>
        <div class="inline-flex items-center gap-2.5 px-6 py-2.5 border border-orange-600/40 text-orange-400 rounded-full group-hover:bg-orange-500 group-hover:text-white group-hover:border-orange-500 transition-all duration-300 text-xs font-mono font-bold uppercase tracking-widest">
          Enter Studio
          <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </div>
      </div>
    </a>

    <!-- Software panel — RIGHT -->
    <a href="/software" class="group relative flex-1 flex items-center justify-center overflow-hidden transition-all duration-700 hover:flex-[1.4]">
      <div class="absolute inset-0 bg-blue-600/5 group-hover:bg-blue-600/10 transition-colors duration-700"></div>
      <div class="absolute inset-0 opacity-20 group-hover:opacity-40 transition-opacity duration-700"
           style="background-image: radial-gradient(circle, rgba(59,130,246,0.4) 1px, transparent 1px); background-size: 28px 28px;"></div>
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="w-96 h-64 rounded-full bg-blue-600/0 group-hover:bg-blue-600/8 blur-3xl transition-all duration-700"></div>
      </div>
      <div class="relative z-10 text-center p-8">
        <span class="text-blue-400 font-mono text-[12px] uppercase tracking-[0.3em] mb-4 block opacity-60 group-hover:opacity-100 transition-opacity">Technical Architecture</span>
        <h2 class="font-grotesk text-4xl md:text-6xl font-extrabold text-white mb-8 leading-none tracking-tight uppercase">
          SOFTWARE<br/><span class="text-blue-400">ENGINEER</span>
        </h2>
        <div class="inline-flex items-center gap-2.5 px-6 py-2.5 border border-blue-600/40 text-blue-400 rounded-full group-hover:bg-blue-500 group-hover:text-white group-hover:border-blue-500 transition-all duration-300 text-xs font-mono font-bold uppercase tracking-widest">
          Enter Lab
          <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </div>
      </div>
    </a>

    <!-- Company bar -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-40 w-[88%] max-w-2xl pointer-events-none">
      <div class="group/bar bg-zinc-950/70 backdrop-blur-md border border-zinc-800 px-4 py-3 md:p-5 rounded-xl md:rounded-3xl shadow-2xl flex flex-row md:flex-col items-center justify-center gap-4 pointer-events-auto transition-all hover:border-zinc-700">
        <span class="relative z-10 font-mono text-[9px] md:text-[10px] font-bold text-zinc-400 uppercase tracking-[0.4em] shrink-0">Proven Impact At</span>
        <div class="relative z-10 flex items-center justify-center gap-5 md:gap-12 opacity-60 grayscale group-hover/bar:opacity-100 group-hover/bar:grayscale-0 transition-all duration-500">
          <img src="/logos/rivalry.png"  alt="Rivalry" class="h-4 md:h-10 w-auto object-contain" />
          <img src="/logos/yohoho.png"   alt="Yohoho"  class="h-4 md:h-10 w-auto object-contain" />
          <img src="/logos/epulze.png"   alt="Epuzle"  class="h-4 md:h-10 w-auto object-contain" />
          <img src="/logos/ncgc.png"     alt="NCGC"    class="h-4 md:h-10 w-auto object-contain" />
        </div>
      </div>
    </div>
  </section>


  <!-- ─── MAIN ─────────────────────────────────────────────────────────────── -->
  <main class="relative z-10 max-w-5xl mx-auto px-6 py-24 space-y-32">


    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 2 · EMPLOYMENT TIMELINE                                        -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <section class="reveal-section">
      <div class="flex items-center gap-4 mb-16">
        <span class="font-mono text-xs font-bold text-zinc-400 uppercase tracking-[0.35em] whitespace-nowrap">// career</span>
        <div class="h-px flex-1 bg-zinc-800/50"></div>
      </div>

      <div class="relative">
        <!-- Vertical spine line -->
        <div class="timeline-spine absolute left-[7px] md:left-[11px] top-3 bottom-3 w-px"></div>

        <div class="space-y-0">
          {allExperiences.map((exp, i) => (
            <div
              class="timeline-item group relative pl-8 md:pl-12 pb-10 cursor-pointer"
              data-modal-id={exp.id}
              style={`--exp-color: ${exp.color}`}
            >
              <!-- Timeline dot -->
              <div class="timeline-dot absolute left-0 top-2 w-[15px] h-[15px] md:w-[23px] md:h-[23px] rounded-full border-2 border-zinc-700 bg-zinc-950 transition-all duration-300 group-hover:scale-110"></div>

              <!-- Card -->
              <div class="relative bg-zinc-900/20 backdrop-blur-sm border border-zinc-800/50 rounded-2xl p-5 md:p-6 transition-all duration-300 group-hover:border-zinc-700 group-hover:-translate-y-0.5 group-hover:shadow-[0_8px_32px_-8px_rgba(0,0,0,0.5)] overflow-hidden">
                <!-- Left accent bar -->
                <div class="timeline-accent absolute left-0 top-0 bottom-0 w-[3px] rounded-l-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

                <div class="flex items-start justify-between gap-4 mb-3">
                  <div class="flex items-center gap-3">
                    <div class="timeline-badge w-8 h-8 md:w-9 md:h-9 rounded-xl flex items-center justify-center font-bold text-sm shrink-0">
                      {exp.company.charAt(0)}
                    </div>
                    <div>
                      <h3 class="text-sm md:text-base font-semibold text-white leading-tight">{exp.title}</h3>
                      <p class="text-xs text-zinc-500 mt-0.5">{exp.company}</p>
                    </div>
                  </div>
                  <div class="text-right shrink-0">
                    <span class="font-mono text-[11px] md:text-xs text-zinc-300 font-semibold uppercase tracking-wider block">{exp.date}</span>
                    <span
                      class="font-mono text-[10px] uppercase tracking-widest px-2 py-0.5 rounded-full border mt-1 inline-block"
                      style={`color: ${catStyle[exp.category].color}; border-color: ${catStyle[exp.category].border}; background-color: ${catStyle[exp.category].bg};`}
                    >
                      {exp.category}
                    </span>
                  </div>
                </div>

                <p class="text-xs md:text-sm text-zinc-400 leading-relaxed line-clamp-2 pl-11">{exp.description}</p>
                <div class="mt-3 pl-11 flex items-center gap-1.5 opacity-0 group-hover:opacity-100 transition-opacity duration-200">
                  <span class="font-mono text-[11px] text-zinc-600 uppercase tracking-widest">view details</span>
                  <svg class="w-2.5 h-2.5 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- SECTION 3 · FEATURED PROJECTS                                          -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <section class="reveal-section">
      <div class="flex items-center gap-4 mb-10">
        <span class="font-mono text-xs font-bold text-zinc-400 uppercase tracking-[0.35em] whitespace-nowrap">// work</span>
        <div class="h-px flex-1 bg-zinc-800/50"></div>
      </div>

      <!-- Tab switcher -->
      <div class="flex items-center gap-2 mb-10">
        <button class="project-tab font-mono text-xs px-5 py-2 rounded-lg border transition-all duration-200 uppercase tracking-widest" data-tab="marketing" data-active="true" id="tab-marketing">
          Growth
        </button>
        <button class="project-tab font-mono text-xs px-5 py-2 rounded-lg border transition-all duration-200 uppercase tracking-widest" data-tab="software" id="tab-software">
          Engineering
        </button>
      </div>

      <!-- Panels — both in DOM, only one visible -->
      <div id="panel-marketing" class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {marketingProjects.map(project => <MarketingCard {...project} />)}
      </div>
      <div id="panel-software" class="grid grid-cols-1 sm:grid-cols-2 gap-6 hidden">
        {softwareProjects.map(project => <ProjectCard {...project} />)}
      </div>
    </section>

    <section class="reveal-section">
      <div class="flex items-center gap-4 mb-16">
        <span class="font-mono text-xs font-bold text-zinc-400 uppercase tracking-[0.35em] whitespace-nowrap">// recent achievements</span>
        <div class="h-px flex-1 bg-zinc-800/50"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {stats.map((stat, i) => (
          <div
            class={`stat-card group relative p-6 rounded-2xl bg-zinc-900/20 backdrop-blur-sm border border-zinc-800/50 overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:border-zinc-700 stat-accent-${stat.accent}`}
          >
            <div class={`stat-bar absolute bottom-0 left-0 right-0 h-0.5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 ${stat.accent === 'blue' ? 'bg-blue-500' : 'bg-orange-500'}`}></div>
            <span class="absolute top-4 right-4 font-mono text-[8px] text-zinc-800 group-hover:text-zinc-700 transition-colors">0{i + 1}</span>
            <p class="font-mono text-[12px] font-bold text-zinc-500 uppercase tracking-widest mb-3">{stat.label}</p>
            <p
              class={`stat-number font-mono text-3xl md:text-4xl font-black text-white tracking-tighter transition-colors duration-300 ${stat.accent === 'blue' ? 'group-hover:text-blue-400' : 'group-hover:text-orange-400'}`}
              data-value={stat.value}
            >
              {stat.value}
            </p>
            <p class="font-mono text-[10px] text-zinc-600 font-bold mt-2 uppercase tracking-tighter">{stat.sub}</p>
          </div>
        ))}
      </div>

      <!-- Contact CTA -->
      <div class="mt-16 flex flex-col items-center gap-6 border-t border-zinc-800/50 pt-16">
        <p class="font-mono text-reg font-bold text-zinc-400 uppercase tracking-[0.10em] text-center">Ready to work together?</p>
        <a
          href={`mailto:${contact.email}`}
          class="inline-flex items-center gap-3 px-10 py-4 rounded-xl bg-white text-black font-bold font-mono uppercase text-xs tracking-[0.2em] hover:bg-zinc-100 transition-all active:scale-95 shadow-[0_0_20px_rgba(255,255,255,0.08)]"
        >
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          Send an Email
        </a>
        <div class="flex items-center gap-6">
          <a href={`https://${contact.linkedin}`} target="_blank" rel="noopener noreferrer" class="font-mono text-[12px] font-bold text-zinc-500 uppercase tracking-widest hover:text-white transition-colors">LinkedIn</a>
          <span class="text-zinc-800">/</span>
          <span class="font-mono text-[12px] font-bold text-zinc-500 uppercase tracking-widest">{contact.location}</span>
        </div>
      </div>
    </section>

  </main>

  <div class="h-20"></div>

</BaseLayout>


<style>
  /* ─── TIMELINE ──────────────────────────────────────────────────────────── */
  .timeline-spine {
    background: linear-gradient(to bottom, transparent, #27272a 8%, #27272a 92%, transparent);
  }

  /* Dot glow uses the CSS variable set inline per item */
  .timeline-item:hover .timeline-dot {
    border-color: var(--exp-color);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--exp-color) 15%, transparent);
  }
  .timeline-dot {
    box-shadow: 0 0 0 3px #09090b;
  }

  .timeline-item:hover .timeline-accent {
    background-color: var(--exp-color);
  }
  .timeline-badge {
    background-color: color-mix(in srgb, var(--exp-color) 15%, transparent);
    color: var(--exp-color);
  }

  .timeline-item:last-child { padding-bottom: 0; }

  /* ─── PROJECT TABS ──────────────────────────────────────────────────────── */
  .project-tab {
    background-color: transparent;
    border-color: #3f3f46;
    color: #71717a;
  }
  .project-tab:hover {
    color: #a1a1aa;
    border-color: #52525b;
  }
  .project-tab[data-tab="marketing"][data-active="true"] {
    background-color: rgba(249,115,22,0.1);
    border-color: rgba(249,115,22,0.45);
    color: rgb(251,146,60);
  }
  .project-tab[data-tab="software"][data-active="true"] {
    background-color: rgba(59,130,246,0.1);
    border-color: rgba(59,130,246,0.45);
    color: rgb(96,165,250);
  }

  /* Light mode — explicit so browser default black border never appears */
  :global(html.light) .project-tab {
    background-color: transparent;
    border-color: #d9d6cf;
    color: #78716c;
  }
  :global(html.light) .project-tab:hover {
    border-color: #a8a29e;
    color: #1c1917;
  }
  :global(html.light) .project-tab[data-tab="marketing"][data-active="true"] {
    background-color: rgba(249,115,22,0.08);
    border-color: rgba(249,115,22,0.5);
    color: rgb(234,88,12);
  }
  :global(html.light) .project-tab[data-tab="software"][data-active="true"] {
    background-color: rgba(59,130,246,0.08);
    border-color: rgba(59,130,246,0.5);
    color: rgb(37,99,235);
  }

  /* ─── SCROLL REVEAL ─────────────────────────────────────────────────────── */
  .reveal-section {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.65s ease-out, transform 0.65s ease-out;
  }
  .reveal-section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── LIGHT MODE ─────────────────────────────────────────────────────────── */
  :global(html.light) .timeline-dot { box-shadow: 0 0 0 3px #f4f3f0; }
  :global(html.light) .timeline-spine { background: linear-gradient(to bottom, transparent, #d9d6cf 8%, #d9d6cf 92%, transparent); }
</style>


<script>
  // ─── SCROLL REVEAL ──────────────────────────────────────────────────────────
  const initReveal = () => {
    const sections = document.querySelectorAll('.reveal-section');
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => {
        if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
      }),
      { threshold: 0.08, rootMargin: '0px 0px -48px 0px' }
    );
    sections.forEach(el => io.observe(el));
  };

  // ─── STAT COUNT-UP ──────────────────────────────────────────────────────────
  const initCountUp = () => {
    const els = document.querySelectorAll<HTMLElement>('.stat-number');
    const io = new IntersectionObserver(
      (entries) => entries.forEach(e => {
        if (!e.isIntersecting) return;
        io.unobserve(e.target);
        const el = e.target as HTMLElement;
        const raw = el.dataset.value ?? '';
        const match = raw.match(/^(\$?)(\d+(?:\.\d+)?)(.*)/);
        if (!match) return;
        const [, prefix, numStr, suffix] = match;
        const target = parseFloat(numStr);
        const start = performance.now();
        const duration = 1300;
        const tick = (now: number) => {
          const p = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = `${prefix}${Math.round(eased * target).toLocaleString()}${suffix}`;
          if (p < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }),
      { threshold: 0.5 }
    );
    els.forEach(el => io.observe(el));
  };

  // ─── PROJECT TAB SWITCHER ───────────────────────────────────────────────────
  const initTabs = () => {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.project-tab');
    const panelMarketing = document.getElementById('panel-marketing') as HTMLElement | null;
    const panelSoftware  = document.getElementById('panel-software')  as HTMLElement | null;

    if (!panelMarketing || !panelSoftware) return;

    const setTab = (active: 'marketing' | 'software') => {
      tabs.forEach(t => {
        if (t.dataset.tab === active) {
          t.dataset.active = 'true';
        } else {
          delete t.dataset.active;
        }
      });
      panelMarketing.classList.toggle('hidden', active !== 'marketing');
      panelSoftware.classList.toggle('hidden',  active !== 'software');
    };

    tabs.forEach(t => t.addEventListener('click', () => setTab(t.dataset.tab as 'marketing' | 'software')));
  };

  const init = () => {
    initReveal();
    initCountUp();
    initTabs();
