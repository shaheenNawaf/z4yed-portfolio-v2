---
import BaseLayout from "../layouts/layout.astro";
import SiteNav from "../components/site_nav.astro";
import HeroHome from "../components/hero_home.astro";
import ProofBand from "../components/proof_band.astro";
import ProjectShowcase from "../components/project_showcase.astro";
import ExperienceTimeline from "../components/experience_timeline.astro";
import SkillsGrid from "../components/skills_grid.astro";
import WhyHire from "../components/why_hire.astro";
import Testimonials from "../components/testimonials.astro";
import BookCall from "../components/book_call.astro";
import StickyBar from "../components/sticky_bar.astro";
import SectionHeader from "../components/section_header.astro";
import {
  name,
  contact,
  hub,
  resumes,
  projects,
  featuredHomeIds,
  trustLogos,
} from "../data/resume";

const featured = featuredHomeIds
  .map((id) => projects.find((p) => p.id === id))
  .filter((p): p is NonNullable<typeof p> => Boolean(p));
---

<BaseLayout
  title={`${name} | Full-stack Engineer & Growth Marketer`}
  description="Full-stack software engineer and growth marketer. 2 live SaaS products, $355K+ campaign volume, 4:1 ROAS. Open to full-time roles in SEA."
  track="hub"
  hideToggle={true}
>
  <SiteNav />

  <main id="main" class="relative">
    <HeroHome />

    <!-- Floating trust bar with animated dual-accent border -->
    <div
      class="relative z-40 -mt-10 md:-mt-14 px-4 pointer-events-none"
    >
      <div class="animate-bob max-w-2xl mx-auto pointer-events-auto">
        <div
          class="animate-border-sync floating-glass rounded-2xl px-6 py-3 md:py-4 flex items-center justify-center gap-5 md:gap-8 transition-transform hover:scale-[1.02]"
        >
          <span
            class="font-mono text-[9px] md:text-[10px] font-bold uppercase tracking-[0.35em] text-[color:var(--text-faint)] shrink-0"
          >
            Trusted by
          </span>
          <div
            class="flex items-center gap-5 md:gap-8 opacity-70 grayscale transition-all duration-500 hover:opacity-100 hover:grayscale-0"
          >
            {
              trustLogos.map((l) => (
                <img
                  src={l.src}
                  alt={l.alt}
                  class="h-4 md:h-7 w-auto object-contain"
                />
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <ProofBand />

    <section id="work" class="relative py-16 md:py-24">
      <div class="max-w-6xl mx-auto px-5 md:px-8">
        <SectionHeader label="// work" />
        <div class="flex items-end justify-between gap-4 mb-10 -mt-4">
          <div>
            <h2
              class="font-grotesk text-2xl md:text-3xl font-extrabold text-[color:var(--text)] tracking-tight"
            >
              Featured work
            </h2>
            <p class="muted text-sm md:text-base mt-2 max-w-2xl">
              Selected builds and campaigns. Each one ships real users, real revenue, or real devices, with the problem, solution, and impact in plain language.
            </p>
          </div>
          <a
            href="#contact"
            class="hidden sm:inline-flex items-center gap-1.5 text-[11px] font-bold uppercase tracking-widest text-[color:var(--accent)] hover:text-[color:var(--text)] transition-colors"
          >
            {hub.ctaPrimary}
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6">
          {featured.map((project) => <ProjectShowcase {...project} />)}
        </div>
      </div>
    </section>

    <ExperienceTimeline />
    <SkillsGrid />
    <WhyHire />
    <Testimonials />

    <section id="contact" class="relative py-16 md:py-24">
      <div class="max-w-4xl mx-auto px-5 md:px-8">
        <SectionHeader label="// contact" />

        <div class="text-center mb-10">
          <h2
            class="font-grotesk text-3xl md:text-5xl font-extrabold text-[color:var(--text)] tracking-tight leading-[1.05] max-w-3xl mx-auto"
          >
            Your <span class="accent-marketing">next best hire</span> is already
            here.<br class="hidden sm:block" /> Let's
            <span class="accent-software">make it official</span>.
          </h2>
        </div>

        <div class="relative">
          <div
            class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-80 h-44 rounded-full blur-3xl animate-cta-glow -z-10"
            style="background: linear-gradient(90deg, var(--mkt-soft), var(--sw-soft));"
          >
          </div>
          <BookCall
            title="Book a 15-min intro call"
            subtitle="Short form first. Then pick a time on Google Appointments or reply over email."
            defaultInterest="hybrid"
          />
        </div>

        <div
          class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-[12px] font-mono uppercase tracking-widest muted"
        >
          <a
            href={`mailto:${contact.email}`}
            class="hover:text-[color:var(--text)] transition-colors"
          >
            {contact.email}
          </a>
          <span class="faint">/</span>
          <a
            href={`https://${contact.linkedin}`}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[color:var(--text)] transition-colors"
          >
            LinkedIn
          </a>
          <span class="faint">/</span>
          <a
            href={resumes.software}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[color:var(--text)] transition-colors"
          >
            SWE resume
          </a>
          <span class="faint">/</span>
          <a
            href={resumes.marketing}
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-[color:var(--text)] transition-colors"
          >
            MKT resume
          </a>
        </div>

        <p class="mt-12 text-center">
          <span
            id="heart-trigger"
            class="font-mono text-[10px] font-bold faint uppercase tracking-widest cursor-pointer hover:text-red-500 transition-colors"
            aria-label="Easter egg"
          >
            made with ❤ -shaheen
          </span>
        </p>
      </div>
    </section>
  </main>

  <StickyBar
    ctaText={hub.ctaPrimary}
    contactEmail={contact.email}
    linkedinUrl={contact.linkedin}
    profileImage={contact.profileImage}
    name={name}
    statusText={hub.status}
    resumeUrl={resumes.software}
    ctaHref="#contact"
  />
</BaseLayout>

<script src="../scripts/index-page.ts"></script>
<script src="../scripts/portal.ts"></script>
